#!/usr/bin/env bash
set -euo pipefail

readonly FOCUSRITE_4I4_SINK_PATTERN='^alsa_output\.usb-Focusrite_Scarlett_4i4_4th_Gen_.*\.pro-output-0$'
readonly LOGICAL_SINKS=(multimedia work music-production)

usage() {
  local logical_list
  logical_list="$(printf '%s|' "${LOGICAL_SINKS[@]}")"
  logical_list="${logical_list%|}"
  cat <<EOF
Usage:
  set-output-route list
  set-output-route status
  set-output-route <${logical_list}|all> <studio-monitors|focusrite|laptop-speakers|internal-speakers|speakers|motherboard|node:<node.name>>

Examples:
  set-output-route multimedia studio-monitors
  set-output-route work laptop-speakers
  set-output-route music-production studio-monitors
  set-output-route all node:alsa_output.pci-0000_00_1f.3.analog-stereo
EOF
}

die() {
  printf 'set-output-route: %s\n' "$*" >&2
  exit 1
}

require_commands() {
  local cmd
  for cmd in pw-link grep awk sort uniq sed; do
    command -v "$cmd" >/dev/null 2>&1 || die "missing required command: $cmd"
  done
}

refresh_ports() {
  INPUT_PORTS="$(pw-link -i 2>/dev/null || true)"
  [[ -n "$INPUT_PORTS" ]] || die "could not query PipeWire input ports"
  OUTPUT_PORTS="$(pw-link -o 2>/dev/null || true)"
  [[ -n "$OUTPUT_PORTS" ]] || die "could not query PipeWire output ports"
  LINKS="$(pw-link -l 2>/dev/null || true)"
}

list_physical_sink_nodes() {
  printf '%s\n' "$INPUT_PORTS" \
    | grep -E '^[^[:space:]]+:playback_(FL|FR|AUX0|AUX1)$' \
    | sed -E 's/:playback_(FL|FR|AUX0|AUX1)$//' \
    | sort \
    | uniq \
    | while IFS= read -r node; do
        case "$node" in
          capture.*|input.*)
            continue
            ;;
        esac
        if { printf '%s\n' "$INPUT_PORTS" | grep -Fxq "${node}:playback_FL" \
          && printf '%s\n' "$INPUT_PORTS" | grep -Fxq "${node}:playback_FR"; } \
          || { printf '%s\n' "$INPUT_PORTS" | grep -Fxq "${node}:playback_AUX0" \
            && printf '%s\n' "$INPUT_PORTS" | grep -Fxq "${node}:playback_AUX1"; }; then
          printf '%s\n' "$node"
        fi
      done
}

resolve_focusrite_4i4_sink() {
  printf '%s\n' "$PHYSICAL_SINKS" | grep -Em1 "$FOCUSRITE_4I4_SINK_PATTERN" || true
}

resolve_motherboard_sink() {
  printf '%s\n' "$PHYSICAL_SINKS" \
    | grep -Ev "$FOCUSRITE_4I4_SINK_PATTERN" \
    | grep -m1 '^alsa_output\.' || true
}

resolve_target_node() {
  local target=$1
  case "$target" in
    studio-monitors|focusrite)
      resolve_focusrite_4i4_sink
      ;;
    laptop-speakers|internal-speakers|speakers|motherboard)
      resolve_motherboard_sink
      ;;
    node:*)
      printf '%s\n' "${target#node:}"
      ;;
    *)
      if printf '%s\n' "$PHYSICAL_SINKS" | grep -Fxq "$target"; then
        printf '%s\n' "$target"
      fi
      ;;
  esac
}

is_logical_sink() {
  local logical=$1 known
  for known in "${LOGICAL_SINKS[@]}"; do
    [[ "$known" == "$logical" ]] && return 0
  done
  return 1
}

logical_output_node() {
  local logical=$1

  if is_logical_sink "$logical"; then
    printf 'sink_node.%s\n' "$logical"
    return
  fi

  die "unknown logical sink: $logical"
}

source_ports_for_logical() {
  local logical=$1
  local output_node
  output_node="$(logical_output_node "$logical")"

  printf '%s\n' "$OUTPUT_PORTS" | awk -v prefix="${output_node}:output_" 'index($0, prefix) == 1'
}

target_left_port() {
  local target_node=$1

  if printf '%s\n' "$INPUT_PORTS" | grep -Fxq "${target_node}:playback_FL"; then
    printf '%s\n' "${target_node}:playback_FL"
    return
  fi

  if printf '%s\n' "$INPUT_PORTS" | grep -Fxq "${target_node}:playback_AUX0"; then
    printf '%s\n' "${target_node}:playback_AUX0"
    return
  fi
}

target_right_port() {
  local target_node=$1

  if printf '%s\n' "$INPUT_PORTS" | grep -Fxq "${target_node}:playback_FR"; then
    printf '%s\n' "${target_node}:playback_FR"
    return
  fi

  if printf '%s\n' "$INPUT_PORTS" | grep -Fxq "${target_node}:playback_AUX1"; then
    printf '%s\n' "${target_node}:playback_AUX1"
    return
  fi
}

linked_targets_for_source_port() {
  local source_port=$1
  printf '%s\n' "$LINKS" | awk -v src="$source_port" '
    $0 == src { active = 1; next }
    /^[^[:space:]]/ { active = 0 }
    active && $1 == "|->" { print $2 }
  '
}

physical_target_nodes_for_logical() {
  local logical=$1

  while IFS= read -r source_port; do
    [[ -n "$source_port" ]] || continue
    linked_targets_for_source_port "$source_port"
  done < <(source_ports_for_logical "$logical") \
    | { grep -E ':playback_' || true; } \
    | sed -E 's/:playback_[^:]+$//' \
    | sort \
    | uniq
}

status_line_for_logical() {
  local logical=$1
  local targets
  targets="$(physical_target_nodes_for_logical "$logical")"

  if [[ -z "$targets" ]]; then
    printf '%s -> unassigned\n' "$logical"
    return
  fi

  printf '%s -> %s\n' "$logical" "$(printf '%s' "$targets" | paste -sd ',' -)"
}

disconnect_physical_links() {
  local logical=$1
  local source_port target_port

  while IFS= read -r source_port; do
    [[ -n "$source_port" ]] || continue
    while IFS= read -r target_port; do
      [[ -n "$target_port" ]] || continue
      case "$target_port" in
        *:playback_*)
          pw-link -d "$source_port" "$target_port" 2>/dev/null || true
          ;;
      esac
    done < <(linked_targets_for_source_port "$source_port")
  done < <(source_ports_for_logical "$logical")
}

connect_logical_to_target() {
  local logical=$1
  local target_node=$2
  local output_node target_left target_right
  output_node="$(logical_output_node "$logical")"
  target_left="$(target_left_port "$target_node")"
  target_right="$(target_right_port "$target_node")"

  [[ -n "$target_left" ]] || die "target sink is missing left playback port: $target_node"
  [[ -n "$target_right" ]] || die "target sink is missing right playback port: $target_node"
  printf '%s\n' "$OUTPUT_PORTS" | grep -Fxq "${output_node}:output_FL" \
    || die "logical sink is missing FL output port: $output_node"
  printf '%s\n' "$OUTPUT_PORTS" | grep -Fxq "${output_node}:output_FR" \
    || die "logical sink is missing FR output port: $output_node"

  disconnect_physical_links "$logical"
  pw-link "${output_node}:output_FL" "$target_left"
  pw-link "${output_node}:output_FR" "$target_right"
}

print_status() {
  local logical focusrite_4i4 motherboard
  focusrite_4i4="$(resolve_focusrite_4i4_sink)"
  motherboard="$(resolve_motherboard_sink)"

  printf 'presets:\n'
  printf '  studio-monitors -> %s\n' "${focusrite_4i4:-unavailable}"
  printf '  laptop-speakers -> %s\n' "${motherboard:-unavailable}"
  printf 'logical sinks:\n'
  for logical in "${LOGICAL_SINKS[@]}"; do
    status_line_for_logical "$logical"
  done
}

route_one() {
  local logical=$1
  local target=$2
  local resolved_target

  resolved_target="$(resolve_target_node "$target")"
  [[ -n "$resolved_target" ]] || die "could not resolve target: $target"

  connect_logical_to_target "$logical" "$resolved_target"
  printf '%s -> %s\n' "$logical" "$resolved_target"
}

main() {
  local command logical
  command="${1:-}"

  case "$command" in
    -h|--help|'')
      usage
      ;;
    list)
      require_commands
      refresh_ports
      PHYSICAL_SINKS="$(list_physical_sink_nodes)"
      [[ -n "$PHYSICAL_SINKS" ]] || die "no physical sinks found"
      printf '%s\n' "$PHYSICAL_SINKS"
      ;;
    status)
      require_commands
      refresh_ports
      PHYSICAL_SINKS="$(list_physical_sink_nodes)"
      print_status
      ;;
    all)
      require_commands
      refresh_ports
      PHYSICAL_SINKS="$(list_physical_sink_nodes)"
      [[ $# -eq 2 ]] || die "expected: set-output-route all <target>"
      for logical in "${LOGICAL_SINKS[@]}"; do
        route_one "$logical" "$2"
        refresh_ports
      done
      ;;
    *)
      if is_logical_sink "$command"; then
        require_commands
        refresh_ports
        PHYSICAL_SINKS="$(list_physical_sink_nodes)"
        [[ $# -eq 2 ]] || die "expected: set-output-route $command <target>"
        route_one "$command" "$2"
      else
        usage >&2
        exit 1
      fi
      ;;
  esac
}

main "$@"
