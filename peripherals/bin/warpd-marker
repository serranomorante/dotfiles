#!/usr/bin/env sh

# Purpose: Keep an input-transparent ghost cursor at the point tab+g would jump
# to for the current warpd-last-location state.
#
# Notes: The shell wrapper compiles a small X11 helper into the user's cache on
# first use. The helper uses an override-redirect shaped X11 window with an
# empty input shape, so dwm does not manage it and clicks pass through it.

set -eu

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/warpd-marker"
helper="$cache_dir/warpd-marker-x11-v19"

compile_helper() {
    command -v cc >/dev/null 2>&1 || {
        printf 'warpd-marker: cc is required to build the cached X11 helper\n' >&2
        return 1
    }

    mkdir -p "$cache_dir"
    src="$cache_dir/warpd-marker-x11-v19.c"

    cat >"$src" <<'EOF'
#include <X11/Xatom.h>
#include <X11/Xlib.h>
#include <X11/Xutil.h>
#include <X11/extensions/shape.h>
#include <X11/extensions/Xfixes.h>

#include <errno.h>
#include <limits.h>
#include <signal.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <unistd.h>

struct xy {
    int ok;
    int x;
    int y;
};

static volatile sig_atomic_t running = 1;

static void stop_running(int signo) {
    (void)signo;
    running = 0;
}

static int parse_int(const char *s, int *out) {
    char *end = NULL;
    long value;

    errno = 0;
    value = strtol(s, &end, 10);
    if (errno != 0 || end == s || *end != '\0') {
        return 0;
    }

    *out = (int)value;
    return 1;
}

static int env_int(const char *name, int fallback, int min, int max) {
    const char *value = getenv(name);
    int parsed;

    if (value == NULL || !parse_int(value, &parsed)) {
        return fallback;
    }

    if (parsed < min) {
        return min;
    }
    if (parsed > max) {
        return max;
    }

    return parsed;
}

static void sleep_ms(int ms) {
    struct timespec req;

    if (ms <= 0) {
        return;
    }

    req.tv_sec = ms / 1000;
    req.tv_nsec = (long)(ms % 1000) * 1000000L;
    while (nanosleep(&req, &req) == -1 && errno == EINTR && running) {
    }
}

static unsigned char clamp_u8(int value) {
    if (value < 0) {
        return 0;
    }
    if (value > 255) {
        return 255;
    }
    return (unsigned char)value;
}

static int same_xy(int x1, int y1, int x2, int y2, int threshold) {
    return abs(x1 - x2) <= threshold && abs(y1 - y2) <= threshold;
}

static struct xy read_xy_file(const char *path) {
    struct xy point;
    FILE *file;
    char extra[2];

    point.ok = 0;
    point.x = 0;
    point.y = 0;

    file = fopen(path, "r");
    if (file == NULL) {
        return point;
    }

    if (fscanf(file, " %d %d %1s", &point.x, &point.y, extra) >= 2) {
        point.ok = 1;
    }

    fclose(file);
    return point;
}

static struct xy current_pointer(Display *display, Window root) {
    struct xy point;
    Window root_return, child_return;
    int root_x, root_y, win_x, win_y;
    unsigned int mask;

    point.ok = 0;
    point.x = 0;
    point.y = 0;

    if (XQueryPointer(display, root, &root_return, &child_return, &root_x,
                      &root_y, &win_x, &win_y, &mask)) {
        point.ok = 1;
        point.x = root_x;
        point.y = root_y;
    }

    return point;
}

static struct xy target_point(Display *display, Window root,
                              const char *last_path,
                              const char *previous_path, int threshold) {
    struct xy none;
    struct xy last;
    struct xy previous;
    struct xy current;

    none.ok = 0;
    none.x = 0;
    none.y = 0;

    last = read_xy_file(last_path);
    if (!last.ok) {
        return none;
    }

    current = current_pointer(display, root);
    if (!current.ok) {
        return none;
    }

    if (same_xy(current.x, current.y, last.x, last.y, threshold)) {
        previous = read_xy_file(previous_path);
        if (previous.ok &&
            !same_xy(current.x, current.y, previous.x, previous.y, threshold)) {
            return previous;
        }

        return none;
    }

    return last;
}

static int mask_shift(unsigned long mask) {
    int shift = 0;

    if (mask == 0) {
        return 0;
    }

    while ((mask & 1UL) == 0) {
        mask >>= 1;
        shift++;
    }

    return shift;
}

static int mask_bits(unsigned long mask) {
    int bits = 0;

    while (mask != 0) {
        if ((mask & 1UL) != 0) {
            bits++;
        }
        mask >>= 1;
    }

    return bits;
}

static unsigned long channel_to_mask(int channel, unsigned long mask) {
    int shift;
    int bits;
    unsigned long max_value;

    if (mask == 0) {
        return 0;
    }

    shift = mask_shift(mask);
    bits = mask_bits(mask);
    max_value = (1UL << bits) - 1UL;

    return (((unsigned long)clamp_u8(channel) * max_value + 127UL) / 255UL)
           << shift;
}

static uint32_t visual_pixel(Visual *visual, int red, int green, int blue) {
    return (uint32_t)(channel_to_mask(red, visual->red_mask) |
                      channel_to_mask(green, visual->green_mask) |
                      channel_to_mask(blue, visual->blue_mask));
}

static void set_marker_pixel(uint32_t *pixels, unsigned char *shape, int size,
                             int x, int y, uint32_t color) {
    if (x < 0 || y < 0 || x >= size || y >= size) {
        return;
    }

    pixels[y * size + x] = color;
    shape[y * size + x] = 1;
}

static void draw_thick_point(uint32_t *pixels, unsigned char *shape, int size,
                             int cx, int cy, int radius, uint32_t color) {
    int x, y;

    for (y = cy - radius; y <= cy + radius; y++) {
        for (x = cx - radius; x <= cx + radius; x++) {
            int dx = x - cx;
            int dy = y - cy;

            if (dx * dx + dy * dy <= radius * radius) {
                set_marker_pixel(pixels, shape, size, x, y, color);
            }
        }
    }
}

static void draw_line(uint32_t *pixels, unsigned char *shape, int size, int x1,
                      int y1, int x2, int y2, int radius, uint32_t color) {
    int dx = abs(x2 - x1);
    int dy = abs(y2 - y1);
    int steps = dx > dy ? dx : dy;
    int i;

    if (steps < 1) {
        draw_thick_point(pixels, shape, size, x1, y1, radius, color);
        return;
    }

    for (i = 0; i <= steps; i++) {
        int x = x1 + (x2 - x1) * i / steps;
        int y = y1 + (y2 - y1) * i / steps;
        draw_thick_point(pixels, shape, size, x, y, radius, color);
    }
}

static int scaled(int value, int size) {
    return (value * size + 48) / 96;
}

static void draw_cursor_outline(Visual *visual, uint32_t *pixels,
                                unsigned char *shape, int size,
                                int outer_width, int inner_width) {
    static const int points[][2] = {
        {15, 3},  {6, 78},  {31, 68}, {38, 88},
        {50, 84}, {44, 64}, {79, 54}};
    int count = (int)(sizeof(points) / sizeof(points[0]));
    uint32_t black = visual_pixel(visual, 0, 0, 0);
    uint32_t white = visual_pixel(visual, 255, 255, 255);
    int i;

    memset(pixels, 0, (size_t)size * (size_t)size * sizeof(uint32_t));
    memset(shape, 0, (size_t)size * (size_t)size);

    if (outer_width < 0) {
        outer_width = 0;
    }
    if (inner_width < 0) {
        inner_width = 0;
    }

    for (i = 0; i < count; i++) {
        int next = (i + 1) % count;
        draw_line(pixels, shape, size, scaled(points[i][0], size) + 1,
                  scaled(points[i][1], size) + 1,
                  scaled(points[next][0], size) + 1,
                  scaled(points[next][1], size) + 1, outer_width, black);
    }

    for (i = 0; i < count; i++) {
        int next = (i + 1) % count;
        draw_line(pixels, shape, size, scaled(points[i][0], size),
                  scaled(points[i][1], size), scaled(points[next][0], size),
                  scaled(points[next][1], size), inner_width, white);
    }
}

static int shape_rectangles(const unsigned char *shape, int size,
                            XRectangle **rects_out) {
    XRectangle *rects;
    int count = 0;
    int capacity = size * size;
    int x, y;

    rects = calloc((size_t)capacity, sizeof(XRectangle));
    if (rects == NULL) {
        return 0;
    }

    for (y = 0; y < size; y++) {
        for (x = 0; x < size; x++) {
            if (!shape[y * size + x]) {
                continue;
            }

            rects[count].x = (short)x;
            rects[count].y = (short)y;
            rects[count].width = 1;
            rects[count].height = 1;
            count++;
        }
    }

    *rects_out = rects;
    return count;
}

static void set_window_atom(Display *display, Window win, const char *property,
                            const char *value) {
    Atom prop_atom = XInternAtom(display, property, False);
    Atom value_atom = XInternAtom(display, value, False);
    Atom atom_type = XInternAtom(display, "ATOM", False);

    XChangeProperty(display, win, prop_atom, atom_type, 32, PropModeReplace,
                    (unsigned char *)&value_atom, 1);
}

int main(void) {
    const char *state_dir = getenv("WARPD_MARKER_STATE_DIR");
    const char *runtime_dir;
    char default_state_dir[PATH_MAX];
    char last_path[PATH_MAX];
    char previous_path[PATH_MAX];
    int threshold = env_int("WARPD_MARKER_SAME_XY_THRESHOLD", 50, 1, 500);
    int poll_ms = env_int("WARPD_MARKER_POLL_MS", 100, 20, 2000);
    int size = env_int("WARPD_MARKER_SIZE", 32, 16, 160);
    int outer_width = env_int("WARPD_MARKER_OUTER_WIDTH", 0, 0, 10);
    int inner_width = env_int("WARPD_MARKER_INNER_WIDTH", 0, 0, 8);
    int hotspot_x;
    int hotspot_y;
    int screen, depth;
    int mapped = 0;
    int last_x = INT_MIN;
    int last_y = INT_MIN;
    int raise_ticks = 0;
    Display *display;
    Window root, win;
    Visual *visual;
    XSetWindowAttributes attrs;
    XImage *image;
    uint32_t *pixels;
    unsigned char *shape;
    XRectangle *shape_rects;
    int shape_rect_count;
    GC gc;
    XserverRegion empty_region;

    if (state_dir == NULL || state_dir[0] == '\0') {
        state_dir = getenv("WARPD_LAST_LOCATION_STATE_DIR");
    }

    if (state_dir == NULL || state_dir[0] == '\0') {
        runtime_dir = getenv("XDG_RUNTIME_DIR");
        if (runtime_dir == NULL || runtime_dir[0] == '\0') {
            runtime_dir = "/tmp";
        }

        if (snprintf(default_state_dir, sizeof(default_state_dir),
                     "%s/warpd-last-location", runtime_dir) >=
            (int)sizeof(default_state_dir)) {
            fprintf(stderr, "warpd-marker: state dir path is too long\n");
            return 1;
        }
        state_dir = default_state_dir;
    }

    if (snprintf(last_path, sizeof(last_path), "%s/last", state_dir) >=
            (int)sizeof(last_path) ||
        snprintf(previous_path, sizeof(previous_path), "%s/previous",
                 state_dir) >= (int)sizeof(previous_path)) {
        fprintf(stderr, "warpd-marker: state file path is too long\n");
        return 1;
    }

    signal(SIGINT, stop_running);
    signal(SIGTERM, stop_running);
    signal(SIGHUP, stop_running);

    display = XOpenDisplay(NULL);
    if (display == NULL) {
        fprintf(stderr, "warpd-marker: could not open X display\n");
        return 1;
    }

    screen = DefaultScreen(display);
    root = RootWindow(display, screen);
    visual = DefaultVisual(display, screen);
    depth = DefaultDepth(display, screen);

    memset(&attrs, 0, sizeof(attrs));
    attrs.override_redirect = True;
    attrs.border_pixel = 0;
    win = XCreateWindow(display, root, -size, -size, (unsigned int)size,
                        (unsigned int)size, 0, depth, InputOutput, visual,
                        CWOverrideRedirect | CWBorderPixel,
                        &attrs);

    empty_region = XFixesCreateRegion(display, NULL, 0);
    XFixesSetWindowShapeRegion(display, win, ShapeInput, 0, 0, empty_region);
    XFixesDestroyRegion(display, empty_region);

    XStoreName(display, win, "warpd-marker");
    set_window_atom(display, win, "_NET_WM_WINDOW_TYPE",
                    "_NET_WM_WINDOW_TYPE_UTILITY");
    set_window_atom(display, win, "_NET_WM_STATE", "_NET_WM_STATE_ABOVE");

    pixels = calloc((size_t)size * (size_t)size, sizeof(uint32_t));
    if (pixels == NULL) {
        XDestroyWindow(display, win);
        XCloseDisplay(display);
        return 1;
    }
    shape = calloc((size_t)size * (size_t)size, sizeof(unsigned char));
    if (shape == NULL) {
        free(pixels);
        XDestroyWindow(display, win);
        XCloseDisplay(display);
        return 1;
    }

    draw_cursor_outline(visual, pixels, shape, size, outer_width, inner_width);
    shape_rect_count = shape_rectangles(shape, size, &shape_rects);
    if (shape_rect_count <= 0) {
        free(shape);
        free(pixels);
        XDestroyWindow(display, win);
        XCloseDisplay(display);
        return 1;
    }
    XShapeCombineRectangles(display, win, ShapeBounding, 0, 0, shape_rects,
                            shape_rect_count, ShapeSet, Unsorted);
    free(shape_rects);

    image = XCreateImage(display, visual, (unsigned int)depth, ZPixmap, 0,
                         (char *)pixels, (unsigned int)size,
                         (unsigned int)size, 32, 0);
    if (image == NULL) {
        free(pixels);
        XDestroyWindow(display, win);
        XCloseDisplay(display);
        return 1;
    }

    gc = XCreateGC(display, win, 0, NULL);
    hotspot_x = scaled(15, size);
    hotspot_y = scaled(3, size);

    while (running) {
        struct xy target =
            target_point(display, root, last_path, previous_path, threshold);

        if (!target.ok) {
            if (mapped) {
                XUnmapWindow(display, win);
                XFlush(display);
                mapped = 0;
                last_x = INT_MIN;
                last_y = INT_MIN;
            }
        } else if (!mapped || target.x != last_x || target.y != last_y) {
            int left = target.x - hotspot_x;
            int top = target.y - hotspot_y;
            XMoveWindow(display, win, left, top);
            XPutImage(display, win, gc, image, 0, 0, 0, 0,
                      (unsigned int)size, (unsigned int)size);
            XMapRaised(display, win);
            XFlush(display);
            mapped = 1;
            last_x = target.x;
            last_y = target.y;
            raise_ticks = 0;
        } else {
            raise_ticks += poll_ms;
            if (raise_ticks >= 1000) {
                XRaiseWindow(display, win);
                XFlush(display);
                raise_ticks = 0;
            }
        }

        sleep_ms(poll_ms);
    }

    if (mapped) {
        XUnmapWindow(display, win);
    }
    XFreeGC(display, gc);
    image->data = (char *)pixels;
    XDestroyImage(image);
    free(shape);
    XDestroyWindow(display, win);
    XCloseDisplay(display);

    return 0;
}
EOF

    cc "$src" -O2 -o "$helper" -lX11 -lXext -lXfixes
}

[ -x "$helper" ] || compile_helper

exec "$helper"
