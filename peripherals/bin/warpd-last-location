#!/usr/bin/env sh

# Tracks the last warpd-selected point and the previous cursor point in tmpfs.
# `run-hint` records the cursor position before opening warpd as `previous`,
# then stores the selected warpd target as `last`. `toggle` jumps between these
# two points: if the cursor is already near `last`, it moves to `previous`;
# otherwise it moves to `last` and refreshes `previous` only when the current
# point is far enough from both stored points. The proximity threshold prevents
# tiny cursor adjustments from collapsing the two toggle endpoints.

set -u

state_dir="${XDG_RUNTIME_DIR:-/tmp}/warpd-last-location"
last_file="$state_dir/last"
previous_file="$state_dir/previous"
lock_dir="$state_dir/lock"
same_xy_threshold=50

is_int() {
    case "$1" in
    '')
        return 1
        ;;
    esac

    case "$1" in
    -*)
        n="${1#-}"
        ;;
    *)
        n="$1"
        ;;
    esac

    case "$n" in
    '' | *[!0-9]*)
        return 1
        ;;
    esac
}

abs() {
    n="$1"
    if [ "$n" -lt 0 ]; then
        printf '%s\n' "$((-n))"
    else
        printf '%s\n' "$n"
    fi
}

same_xy() {
    dx="$(abs $(($1 - $3)))"
    dy="$(abs $(($2 - $4)))"

    [ "$dx" -le "$same_xy_threshold" ] && [ "$dy" -le "$same_xy_threshold" ]
}

save_xy_file() {
    file="$1"
    x="$2"
    y="$3"

    is_int "$x" && is_int "$y" || return 1
    mkdir -p "$state_dir" || return 1

    tmp="$file.$$"
    printf '%s %s\n' "$x" "$y" >"$tmp" && mv "$tmp" "$file"
}

save_last_xy() {
    x="$1"
    y="$2"

    previous_xy="$(read_xy_file "$previous_file")" || previous_xy=""
    if [ -n "$previous_xy" ]; then
        set -- $previous_xy "$x" "$y"
        same_xy "$1" "$2" "$3" "$4" && return 0
    fi

    save_xy_file "$last_file" "$x" "$y"
}

save_previous_xy() {
    x="$1"
    y="$2"

    last_xy="$(read_xy_file "$last_file")" || last_xy=""
    if [ -n "$last_xy" ]; then
        set -- $last_xy "$x" "$y"
        same_xy "$1" "$2" "$3" "$4" && return 0
    fi

    previous_xy="$(read_xy_file "$previous_file")" || previous_xy=""
    if [ -n "$previous_xy" ]; then
        set -- $previous_xy "$x" "$y"
        same_xy "$1" "$2" "$3" "$4" && return 0
    fi

    save_xy_file "$previous_file" "$x" "$y"
}

save_previous_xy_force() {
    save_xy_file "$previous_file" "$1" "$2"
}

current_xy() {
    location="$(xdotool getmouselocation --shell 2>/dev/null)" || return 1
    eval "$location"

    is_int "${X:-}" && is_int "${Y:-}" || return 1
    printf '%s %s\n' "$X" "$Y"
}

read_xy_file() {
    file="$1"

    [ -r "$file" ] || return 1
    IFS=' ' read -r x y _ <"$file" || return 1

    is_int "${x:-}" && is_int "${y:-}" || return 1
    printf '%s %s\n' "$x" "$y"
}

with_lock() {
    tries=0

    while ! mkdir "$lock_dir" 2>/dev/null; do
        tries=$((tries + 1))
        if [ "$tries" -ge 50 ]; then
            rmdir "$lock_dir" 2>/dev/null || return 1
            tries=0
        fi

        sleep 0.01
    done

    trap 'rmdir "$lock_dir" 2>/dev/null' EXIT HUP INT TERM
}

run_hint() {
    before_xy="$(current_xy)" || before_xy=""
    mkdir -p "$state_dir" || return 1

    output_file="$state_dir/run-hint.$$"
    warpd_child=""

    # keyd-observer may cancel this helper when tab+f is pressed again. Keep
    # warpd as a direct child and forward termination so the old overlay closes
    # immediately, while still allowing stdout parsing on a normal selection.
    stop_warpd_child() {
        [ -n "${warpd_child:-}" ] && kill "$warpd_child" >/dev/null 2>&1 || true
        [ -n "${warpd_child:-}" ] && wait "$warpd_child" 2>/dev/null || true
        rm -f "$output_file"
        exit 143
    }

    trap stop_warpd_child HUP INT TERM

    warpd --config "${WARPD_CONFIG:-$HOME/.config/warpd/config}" --hint --oneshot --foreground >"$output_file" &
    warpd_child="$!"
    wait "$warpd_child"
    rc=$?
    warpd_child=""

    IFS= read -r output <"$output_file" || output=""
    rm -f "$output_file"
    trap - HUP INT TERM

    set -- $output
    if [ "$#" -ge 2 ] && is_int "$1" && is_int "$2"; then
        last_x="$1"
        last_y="$2"

        if [ -n "$before_xy" ]; then
            set -- $before_xy
            save_previous_xy_force "$1" "$2" >/dev/null 2>&1 || true
        fi

        save_last_xy "$last_x" "$last_y" >/dev/null 2>&1 || true
    fi

    return "$rc"
}

toggle() {
    mkdir -p "$state_dir" || return 1
    with_lock

    last_xy="$(read_xy_file "$last_file")" || return 0
    set -- $last_xy
    last_x="$1"
    last_y="$2"

    current_xy="$(current_xy)" || return 1
    set -- $current_xy
    current_x="$1"
    current_y="$2"

    if same_xy "$current_x" "$current_y" "$last_x" "$last_y"; then
        previous_xy="$(read_xy_file "$previous_file")" || return 0
        set -- $previous_xy
        target_x="$1"
        target_y="$2"

        same_xy "$current_x" "$current_y" "$target_x" "$target_y" && return 0
        warpd --move "$target_x $target_y" >/dev/null 2>&1 || return 1
    else
        warpd --move "$last_x $last_y" >/dev/null 2>&1 || return 1
        save_previous_xy "$current_x" "$current_y"
    fi
}

case "${1:-}" in
run-hint)
    run_hint
    ;;
toggle)
    toggle
    ;;
*)
    printf 'usage: %s run-hint|toggle\n' "$0" >&2
    exit 2
    ;;
esac
