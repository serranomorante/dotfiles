[user]
email = example@example.com
name = example

[init]
defaultBranch = main

[rerere]
enabled = false

[commit]
verbose = true

[core]
editor = open_in_nvim git_editor
pager = delta

[interactive]
diffFilter = delta

[merge]
conflictstyle = diff3

[diff]
colorMoved = default
external = bash ~/dotfiles/lazygit/dot-config/lazygit/delta-theme-external-diff

[delta]
default-language = bash
features = settings interactive decorations

[delta "settings"]
true-color = always
detect-dark-light = always
paging = never
line-numbers = true
hyperlinks = true
hyperlinks-file-link-format = "lazygit-edit://{path}:{line}"

[delta "interactive"]
keep-plus-minus-markers = false

[delta "decorations"]
commit-decoration-style = blue
commit-style = raw
file-style = omit
hunk-header-decoration-style = Black box
hunk-header-file-style = Gray bold ul
hunk-header-style = file line-number syntax

[includeIf "gitdir:~/dotfiles/**"]
path = ~/dotfiles/.gitconfig

[includeIf "gitdir:~/data/work/cf/**"]
path = ~/data/work/cf/.gitconfig
