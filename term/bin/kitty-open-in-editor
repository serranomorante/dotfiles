#!/usr/bin/env bash
# Purpose: Edit a file in an existing Kitty window whose cwd is a prefix of the
#   given path. Sends the file (and optional line) to that window's Neovim via
#   open_in_nvim; Neovim focuses its own Kitty window after the remote edit.
# Usage: kitty-open-in-editor PATH[:LINE:]

source "$HOME/dotfiles/term/bin/kitty-dmenu-common.bash"

target=${*:-}
if [[ -z $target ]]; then
    echo "Usage: kitty-open-in-editor PATH[:LINE:]" >&2
    exit 2
fi

if [[ $target =~ ^([^:]+):([^:]+): ]]; then
    file=${BASH_REMATCH[1]}
    line=${BASH_REMATCH[2]}
else
    file=$target
    line=
fi

send_edit_to_kitty() {
    local socket=$1

    if [[ -n $line ]]; then
        kitten @ --to "unix:$socket" run open_in_nvim kitty_simple_edit_at_line "$file" "$line" >/dev/null
    else
        kitten @ --to "unix:$socket" run open_in_nvim kitty_simple_edit "$file" >/dev/null
    fi
}

try_open_on_entries() {
    local entries=$1
    local cwd socket

    while IFS=$'\t' read -r cwd socket; do
        [[ -n $cwd && -n $socket ]] || continue
        [[ $target == "$cwd"* ]] || continue

        if send_edit_to_kitty "$socket"; then
            return 0
        fi
    done <<<"$entries"

    return 1
}

attempt() {
    local force_refresh=$1
    local sockets=()
    local entries

    readarray -t sockets < <(kitty_dmenu_socket_list "$force_refresh")
    ((${#sockets[@]} > 0)) || return 1

    entries=$(kitty_dmenu_collect_window_entries "${sockets[@]}")
    [[ -n $entries ]] || return 1

    try_open_on_entries "$entries"
}

if attempt 0 || attempt 1; then
    exit 0
fi

echo "No matching kitty window found for path: $target" >&2
exit 1
