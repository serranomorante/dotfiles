#!/usr/bin/env bash
# Purpose: Edit a file in the CWD-derived Neovim server for the given path.
# Usage: kitty-open-in-editor PATH[:LINE:]

source "$HOME/dotfiles/term/bin/kitty-dmenu-common.bash"

target=${*:-}
if [[ -z $target ]]; then
    echo "Usage: kitty-open-in-editor PATH[:LINE:]" >&2
    exit 2
fi

if [[ $target =~ ^([^:]+):([^:]+): ]]; then
    file=${BASH_REMATCH[1]}
    line=${BASH_REMATCH[2]}
else
    file=$target
    line=
fi

send_edit_to_cwd() {
    local cwd=$1
    local edit_file=${2:-$file}

    if [[ -n $line ]]; then
        open_in_nvim --cwd "$cwd" kitty_simple_edit_at_line "$edit_file" "$line" >/dev/null
    else
        open_in_nvim --cwd "$cwd" kitty_simple_edit "$edit_file" >/dev/null
    fi
}

absolute_file_path() {
    local path=$1

    case $path in
    /*) printf '%s\n' "$path" ;;
    *) printf '%s/%s\n' "${PWD%/}" "$path" ;;
    esac
}

containing_dir() {
    local path=$1
    local dir

    if [[ -d $path ]]; then
        dir=$path
    else
        dir=${path%/*}
        [[ $dir != "$path" ]] || dir=.
    fi

    (cd "$dir" 2>/dev/null && pwd)
}

parent_dir() {
    local dir=${1%/}

    if [[ -z $dir || $dir == "/" ]]; then
        printf '/\n'
    else
        dir=${dir%/*}
        printf '%s\n' "${dir:-/}"
    fi
}

try_open_on_parent_servers() {
    local abs_file dir socket

    abs_file=$(absolute_file_path "$file")
    dir=$(containing_dir "$abs_file") || return 1

    while true; do
        socket=$(kitty_dmenu_nvim_servername_for_cwd "$dir")
        if [[ -S $socket ]] && send_edit_to_cwd "$dir" "$abs_file"; then
            return 0
        fi

        [[ $dir != "/" ]] || break
        dir=$(parent_dir "$dir")
    done

    return 1
}

if try_open_on_parent_servers; then
    exit 0
fi

echo "No matching Neovim server found for path: $target" >&2
exit 1
