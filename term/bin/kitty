#!/usr/bin/env bash
# Purpose: Start Kitty with cwd-derived instance and remote-control sockets.

. "$HOME/dotfiles/term/bin/kitty-window-utils.sh"

kitty_os_instance_id=$(uuidgen)
cwd=${PWD:-}
args=("$@")

for ((i = 0; i < ${#args[@]}; i++)); do
    case ${args[$i]} in
    -d | --directory | --working-directory)
        if ((i + 1 < ${#args[@]})); then
            cwd=${args[$((i + 1))]}
            i=$((i + 1))
        fi
        ;;
    --directory=* | --working-directory=*)
        cwd=${args[$i]#*=}
        ;;
    esac
done

kitty_socket=$(kitty_listen_on_for_cwd "$cwd")

KITTY_OS_INSTANCE_ID="$kitty_os_instance_id" \
    KITTY_LISTEN_ON="$kitty_socket" \
    ~/.local/kitty.app/bin/kitty --listen-on "$kitty_socket" "$@"
