#!/usr/bin/env bash
# Purpose: Pick one currently open Kitty working directory and focus it.

source "$HOME/dotfiles/term/bin/kitty-dmenu-common.bash"

kitty_dmenu_currently_opened_main() {
    local tmpdir entries_file choices_file selected_file selected socket

    tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/kitty-dmenu-current.XXXXXX") || exit 1
    trap 'rm -rf "$tmpdir"' EXIT

    entries_file=$tmpdir/entries.tsv
    choices_file=$tmpdir/choices
    selected_file=$tmpdir/selected

    kitty_dmenu_cached_window_entries >"$entries_file"
    awk -F '\t' '{ print $1 }' "$entries_file" >"$choices_file"

    kitty --class kitty-dmenu -o tab_bar_style=hidden bash -c \
        'source "$HOME/dotfiles/term/bin/kitty-dmenu-common.bash"
        kitty_dmenu_run_refreshing_fzf "$1" "$2" "Select cwd: " kitty_dmenu_open_cwd_choices "$3"' \
        bash "$choices_file" "$selected_file" "$entries_file" || true

    if [[ -f $selected_file ]]; then
        selected=$(<"$selected_file")
    else
        selected=
    fi
    [[ -n $selected ]] || exit 0

    socket=$(awk -F '\t' -v cwd="$selected" '$1 == cwd { print $2; exit }' "$entries_file")

    if [[ -n $socket ]] && kitty_dmenu_focus_cwd_on_sockets "$selected" "$socket"; then
        exit 0
    fi

    kitty_dmenu_window_entries 1 >"$entries_file"
    socket=$(awk -F '\t' -v cwd="$selected" '$1 == cwd { print $2; exit }' "$entries_file")

    if [[ -n $socket ]]; then
        kitty_dmenu_focus_cwd_on_sockets "$selected" "$socket" || notify-send "Error: no matching Kitty window for $selected"
    else
        notify-send "Error: no matching Kitty window for $selected"
    fi
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    kitty_dmenu_currently_opened_main "$@"
fi
