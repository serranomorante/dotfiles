# Shared Remind helper functions.
# This file is static; reminders.rem is generated by Neovim.

FSET summer() $Tm >= 5 && $Tm <= 9
FSET summer_every(n) summer() && ((trigdate() - date($Ty, 6, 1)) % n == 0)
FSET last_week(m) $Tm == monnum(m) && day(trigdate()) > daysinmon(trigdate()) - 7
FSET last_week_of(m,y) coerce("STRING", date(y, monnum(m), daysinmon(m,y)-6)) + " THROUGH " + coerce("STRING", date(y, monnum(m), daysinmon(m,y)))
