    commands=$(
        cat <<'EOF'
```sh
SYSTEMD_PAGER='less -R +G' journalctl -u docker.service -u containerd.service -u podman.service --since today -n 300 --pager-end
```

```sh
timeout 3s docker ps -a --format 'container {{.Names}} {{.Status}}' | rg -i 'exited \([1-9][0-9]*\)|unhealthy|restarting' | sed -n '1,200p'
```
EOF
    )

    write_source_page "system-health-containers" "Container Signals" "$count" "$commands" "$signals"
}

