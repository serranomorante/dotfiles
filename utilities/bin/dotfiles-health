#!/bin/sh
# Purpose: Write a compact workstation health report into the Foam notes tree.
# Usage: dotfiles-health update|report|open|check
# Notes: The report links to runnable journalctl/systemctl snippets instead of
# storing raw logs in Markdown.

set -eu

prog=${0##*/}
notes_root=${DOTFILES_HEALTH_NOTES_ROOT:-"$HOME/data/notes/foam"}
health_dir=${DOTFILES_HEALTH_DIR:-"$notes_root/ops/system-health"}
main_file="$health_dir/system-health.md"
rules_file="$health_dir/rules.md"
runbook_file="$health_dir/runbook.md"
units_dir="$health_dir/units"
sources_dir="$health_dir/sources"
hardware_sources_dir="$sources_dir/hardware"
app_sources_dir="$sources_dir/apps"
discovery_sources_dir="$sources_dir/discovery"
reports_dir="$health_dir/reports"
spikes_state_dir=${DOTFILES_SPIKES_STATE_DIR:-"$HOME/.local/state/dotfiles/system-spikes"}
spike_events_dir="$spikes_state_dir/events"
manual_start='<!-- dotfiles-health:manual-reminders:start -->'
manual_end='<!-- dotfiles-health:manual-reminders:end -->'

usage() {
    cat >&2 <<EOF
Usage:
  $prog update    Regenerate the Foam Markdown health report
  $prog report    Print the current report path
  $prog open      Print the current report path
  $prog check     Print current user failed units
EOF
    exit 2
}

positive_int_or_default() {
    case "$1" in
    '' | *[!0-9]* | 0) printf '%s\n' "$2" ;;
    *) printf '%s\n' "$1" ;;
    esac
}

journal_lines=$(positive_int_or_default "${DOTFILES_HEALTH_JOURNAL_LINES:-1000}" 1000)
kernel_journal_lines=$(positive_int_or_default "${DOTFILES_HEALTH_KERNEL_JOURNAL_LINES:-5000}" 5000)
run_cache_dir=

cleanup_run_cache() {
    [ -n "$run_cache_dir" ] || return 0
    rm -rf "$run_cache_dir"
}

init_run_cache() {
    run_cache_dir=$(mktemp -d)
    trap cleanup_run_cache EXIT
}

journal_cache_key() {
    printf '%s\n' "$@" | cksum | awk '{print $1 "-" $2}'
}

journal_today() {
    if [ -z "$run_cache_dir" ]; then
        journalctl --since today -n "$journal_lines" --no-pager "$@" 2>/dev/null
        return
    fi

    key=$(journal_cache_key "$@")
    cache_file="$run_cache_dir/journal-$key.log"
    if [ ! -f "$cache_file" ]; then
        tmp_file="$cache_file.tmp"
        if journalctl --since today -n "$journal_lines" --no-pager "$@" >"$tmp_file" 2>/dev/null; then
            mv "$tmp_file" "$cache_file"
        else
            rm -f "$tmp_file"
            : >"$cache_file"
        fi
    fi
    cat "$cache_file"
}

kernel_journal_today() {
    if [ -z "$run_cache_dir" ]; then
        journalctl -k --since today -n "$kernel_journal_lines" --no-pager 2>/dev/null
        return
    fi

    cache_file="$run_cache_dir/kernel-journal.log"
    if [ ! -f "$cache_file" ]; then
        tmp_file="$cache_file.tmp"
        if journalctl -k --since today -n "$kernel_journal_lines" --no-pager >"$tmp_file" 2>/dev/null; then
            mv "$tmp_file" "$cache_file"
        else
            rm -f "$tmp_file"
            : >"$cache_file"
        fi
    fi
    cat "$cache_file"
}

now_local() {
    date '+%Y-%m-%d %H:%M:%S %Z'
}

today() {
    date '+%Y-%m-%d'
}

year_month() {
    date '+%Y-%m'
}

year_now() {
    date '+%Y'
}

compact_blank_lines() {
    awk '
        NF == 0 {
            blank++
            if (blank <= 1) {
                print
            }
            next
        }
        {
            blank = 0
            print
        }
    '
}

markdown_text() {
    printf '%s\n' "$1" | sed 's/`/\\`/g'
}

ensure_dirs() {
    mkdir -p \
        "$health_dir" \
        "$units_dir" \
        "$sources_dir" \
        "$hardware_sources_dir" \
        "$app_sources_dir" \
        "$discovery_sources_dir" \
        "$reports_dir/$(year_now)"
}

run_or_empty() {
    "$@" 2>/dev/null || true
}

count_lines() {
    awk 'NF {count++} END {print count + 0}'
}

failed_units() {
    output=$(systemctl --user --failed --plain --no-legend 2>/dev/null) || {
        printf '%s\n' 'dotfiles-health-user-bus-unavailable.service'
        return
    }
    printf '%s\n' "$output" |
        awk '$1 != "" {print $1}'
}

failed_count() {
    failed_units | count_lines
}

system_failed_units() {
    output=$(systemctl --failed --plain --no-legend 2>/dev/null) || {
        printf '%s\n' 'dotfiles-health-system-bus-unavailable.service'
        return
    }
    printf '%s\n' "$output" |
        awk '$1 != "" {print $1}'
}

system_failed_count() {
    system_failed_units | count_lines
}

coredump_summary_since() {
    since=$1
    coredumpctl list --since "$since" --no-pager 2>/dev/null |
        awk '
            NR > 1 && NF >= 10 {
                sig = $8
                exe = $(NF - 1)
                sub(".*/", "", exe)
                if (sig != "" && exe != "") {
                    key = exe " " sig
                    count[key]++
                }
            }
            END {
                for (key in count) {
                    print count[key] "\t" key
                }
            }
        ' |
        sort -rn |
        head -10
}

coredump_count_since() {
    since=$1
    coredump_summary_since "$since" | awk -F '\t' '{sum += $1} END {print sum + 0}'
}

xorg_log_files() {
    for file in /var/log/Xorg.0.log "$HOME/.local/share/xorg/Xorg.0.log"; do
        [ -r "$file" ] && printf '%s\n' "$file"
    done
    true
}

xorg_offset() {
    printf '%s\n' "$1" |
        sed 's/^\[\([ 0-9.]*\)\].*/\1/; s/ //g'
}

xorg_signal_lines_for_file() {
    file=$1
    start_line=$(awk '/Log file: .* Time: / {print; exit}' "$file" 2>/dev/null || true)
    start_time=$(printf '%s\n' "$start_line" | sed 's/.*Time: //')
    start_offset=$(xorg_offset "$start_line")
    start_epoch=

    if [ -n "$start_time" ] && [ -n "$start_offset" ]; then
        start_epoch=$(date -d "$start_time" '+%s' 2>/dev/null || true)
    fi

    awk '
        /\((EE|WW)\)/ &&
        $0 !~ /\(WW\) warning, \(EE\) error/ &&
        $0 !~ /The directory .* does not exist/ {
            print
        }
    ' "$file" 2>/dev/null | while IFS= read -r line; do
        [ -n "$line" ] || continue
        offset=$(xorg_offset "$line")
        if [ -n "$start_epoch" ] && [ -n "$start_offset" ] && [ -n "$offset" ]; then
            delta=$(awk -v offset="$offset" -v start="$start_offset" 'BEGIN {printf "%d", offset - start}')
            stamp=$(date -d "@$((start_epoch + delta))" '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null || true)
            rest=$(printf '%s\n' "$line" | sed 's/^\[[^]]*\] *//')
            if [ -n "$stamp" ]; then
                printf '%s (%s) %s\n' "$stamp" "xorg+$offset" "$rest"
                continue
            fi
        fi
        printf '%s\n' "$line"
    done
}

xorg_signal_lines() {
    files=$(xorg_log_files)
    if [ -n "$files" ]; then
        printf '%s\n' "$files" | while IFS= read -r file; do
            [ -n "$file" ] || continue
            xorg_signal_lines_for_file "$file"
        done
    fi
    kernel_journal_today |
        awk '
            {
                line = tolower($0)
            }
            (line ~ /nvidia-modeset/ && line ~ /warning/) ||
            (line ~ /(nvrm:|drm|libinput)/ && line ~ /(xid|failed|error)/) {
                print
            }
        '
}

xorg_signal_count() {
    xorg_signal_lines | count_lines
}

pacman_signal_lines() {
    [ -r /var/log/pacman.log ] || return 0
    day=$(today)
    awk -v day="$day" '
        index($0, "[" day) == 1 &&
        $0 ~ /(error:|failed|WARNING|Error!|exited [1-9]|aborted|Possibly missing firmware)/ {
            print
        }
    ' /var/log/pacman.log
}

pacman_signal_count() {
    pacman_signal_lines | count_lines
}

kernel_signal_lines() {
    kernel_journal_today |
        awk '
            {
                line = tolower($0)
            }
            line ~ /(oom-kill|out of memory|i\/o error|ext4-fs error|bug:|warning: cpu|call trace|machine check)/ ||
            line ~ /mce:.*(hardware error|error|cpu|bank|status)/ ||
            (line ~ /btrfs/ && line ~ /(error|corrupt)/) ||
            (line ~ /nvrm:/ && line ~ /(xid|failed|error|fallen off|rminitadapter)/) ||
            (line ~ /amdgpu/ && line ~ /(mode2 reset|gpu reset|timeout|failed|error|ring .* timeout)/) ||
            (line ~ /thermal/ && line ~ /(critical|thrott)/) {
                print
            }
        '
}

kernel_signal_count() {
    kernel_signal_lines | count_lines
}

audio_signal_lines() {
    journal_today --user -u pipewire.service -u pipewire-pulse.service -u wireplumber.service |
        awk '
            {
                line = tolower($0)
            }
            (line ~ /spa\.alsa/ && line ~ /(no such device|resync|operation not permitted)/) ||
            (line ~ /spa\.audioconvert/ && line ~ /out of buffers/) ||
            (line ~ /(pipewire|wireplumber)/ && line ~ /(error|failed|no such device)/) {
                print
            }
        '
}

audio_signal_count() {
    audio_signal_lines | count_lines
}

redact_log_lines() {
    sed -E \
        -e 's/((api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|token|password|passwd|secret)=)[^&[:space:]"'\'']+/\1[REDACTED]/Ig' \
        -e 's/(Authorization: Bearer )[A-Za-z0-9._~+\/=-]+/\1[REDACTED]/Ig'
}

network_signal_lines() {
    journal_today \
        -u NetworkManager.service \
        -u systemd-networkd.service \
        -u systemd-resolved.service \
        -u iwd.service \
        -u wpa_supplicant.service \
        -u tailscaled.service |
        awk '
            {
                line = tolower($0)
            }
            line ~ /<info>/ && line !~ /(failed|failure|error|timed out|unreachable|deauth|link is down)/ {
                next
            }
            line ~ /(<warn>|<error>|failed|failure|error|timed out|unreachable|deauth|link is down|dhcp.*(failed|timed out)|dns.*(failed|timed out)|vpn.*(failed|error)|wireguard.*(failed|error))/ {
                print
            }
        ' |
        redact_log_lines
}

network_signal_count() {
    network_signal_lines | count_lines
}

bluetooth_signal_lines() {
    {
        journal_today -u bluetooth.service
        kernel_journal_today |
            awk '/Bluetooth|hci[0-9]/ {print}'
    } |
        awk '
            {
                line = tolower($0)
            }
            line ~ /(failed|failure|error|timeout|timed out|hci.*(down|reset|failed|error)|br-connection|sco packet)/ {
                print
            }
        ' |
        redact_log_lines
}

bluetooth_signal_count() {
    bluetooth_signal_lines | count_lines
}

storage_signal_lines() {
    kernel_journal_today |
        awk '
            {
                line = tolower($0)
            }
            line ~ /(i\/o error|blk_update_request|buffer i\/o|read-only file system)/ ||
            (line ~ /nvme/ && line ~ /(error|reset|timeout|critical|smart|abort)/) ||
            (line ~ /ata[0-9]/ && line ~ /(error|failed|timeout|hard resetting)/) ||
            (line ~ /ext4-fs/ && line ~ /(error|warning)/) ||
            (line ~ /btrfs/ && line ~ /(error|warning|corrupt)/) ||
            (line ~ /xfs/ && line ~ /(error|corrupt)/) ||
            (line ~ /filesystem/ && line ~ /remount/) {
                print
            }
        ' |
        redact_log_lines
}

storage_signal_count() {
    storage_signal_lines | count_lines
}

container_signal_lines() {
    {
        journal_today \
            -u docker.service \
            -u containerd.service \
            -u podman.service
        timeout 3s docker ps -a --format 'container {{.Names}} {{.Status}}' 2>/dev/null || true
    } |
        awk '
            {
                line = tolower($0)
            }
            line ~ /(level=(warning|error)|failed|failure|panic|exited \([1-9][0-9]*\)|unhealthy|restarting)/ {
                print
            }
        ' |
        redact_log_lines
}

container_signal_count() {
    container_signal_lines | count_lines
}

sync_signal_lines() {
    journal_today --user -u syncthing.service |
        awk '
            {
                line = tolower($0)
            }
            line ~ /(failed|failure|error|timeout|out of sync|folder marker|conflict|connection refused|no such host)/ {
                print
            }
        ' |
        redact_log_lines
}

sync_signal_count() {
    sync_signal_lines | count_lines
}

editor_signal_lines() {
    day=$(today)
    for file in \
        "$HOME/.local/state/nvim/logs/lsp.log" \
        "$HOME/.local/state/nvim/log" \
        "$HOME/.local/state/nvim/overseer.log"; do
        [ -r "$file" ] || continue
        tail -400 "$file" 2>/dev/null |
            awk -v file="$file" -v day="$day" '
                index($0, day) == 0 {
                    next
                }
                {
                    line = tolower($0)
                }
                line ~ /report upstream, this warning is harmless/ {
                    next
                }
                line ~ /"stderr".*\[[0-9:]+ inf\]/ {
                    next
                }
                line ~ /(error|warn|failed|failure|traceback|panic|exception)/ &&
                line !~ /"stderr"[[:space:]]+"i\[/ {
                    print file ": " $0
                }
            '
    done |
        redact_log_lines
}

editor_signal_count() {
    editor_signal_lines | count_lines
}

music_signal_lines() {
    {
        journalctl --user --since today -n 1000 --no-pager 2>/dev/null |
            awk '
                {
                    line = tolower($0)
                }
                line ~ /promnesia\[[0-9]+\]: \[debug[[:space:]]+[0-9-]+ [0-9:]+ promnesia .* indexing via _markdown:/ {
                    next
                }
                line ~ /(reaper|yabridge|wineasio|wine)/ && line ~ /(failed|failure|error|timeout|crash)/ {
                    print
                }
            '
        for file in \
            "$HOME"/.local/share/yabridge/*.log \
            "$HOME"/.config/yabridge/*.log \
            "$HOME"/.config/REAPER/*.log; do
            [ -r "$file" ] || continue
            tail -400 "$file" 2>/dev/null |
                awk -v file="$file" '
                    {
                        line = tolower($0)
                    }
                    line ~ /(failed|failure|error|timeout|crash|exception|segfault)/ {
                        print file ": " $0
                    }
                '
        done
    } |
        redact_log_lines
}

music_signal_count() {
    music_signal_lines | count_lines
}

security_signal_lines() {
    journal_today \
        -u sshd.service \
        -u ssh.service \
        -u auditd.service \
        -u polkit.service |
        awk '
            {
                line = tolower($0)
            }
            line ~ /(authentication failure|failed password|pam_.*(failure|error)|polkit.*(error|failed|denied)|audit.*(denied|apparmor|selinux|avc)|permission denied)/ {
                print
            }
        ' |
        redact_log_lines
}

security_signal_count() {
    security_signal_lines | count_lines
}

spike_event_count_today() {
    file="$spike_events_dir/$(today).jsonl"
    [ -r "$file" ] || {
        printf '0\n'
        return
    }
    awk 'NF {count++} END {print count + 0}' "$file"
}

journal_warning_lines() {
    {
        journalctl --user -p warning..alert --since today -n 1000 --no-pager 2>/dev/null |
            sed 's/^/[user] /'
        journalctl -p warning..alert --since today -n 1000 --no-pager 2>/dev/null |
            sed 's/^/[system] /'
    } |
        redact_log_lines
}

unclassified_warning_lines() {
    journal_warning_lines |
        awk '
            $0 !~ /^\[(user|system)\] [A-Z][a-z][a-z] [ 0-9][0-9] [0-9][0-9]:[0-9][0-9]:[0-9][0-9] / {
                next
            }
            {
                line = tolower($0)
            }
            (line ~ /spa\.alsa/ && line ~ /(no such device|resync|operation not permitted)/) {next}
            (line ~ /spa\.audioconvert/ && line ~ /out of buffers/) {next}
            (line ~ /(pipewire|wireplumber)/ && line ~ /(error|failed|no such device)/) {next}
            (line ~ /(networkmanager|systemd-resolved|systemd-networkd|wpa_supplicant|iwd|tailscaled)/ && line ~ /(<warn>|<error>|failed|failure|error|timed out|unreachable|deauth|link is down|dhcp|dns|vpn|wireguard)/) {next}
            (line ~ /(bluetooth|hci[0-9])/ && line ~ /(failed|failure|error|timeout|timed out|down|reset|br-connection|sco packet)/) {next}
            (line ~ /(docker|containerd|podman)/ && line ~ /(level=(warning|error)|failed|failure|panic|exited \([1-9][0-9]*\)|unhealthy|restarting)/) {next}
            line ~ /(container .*exited \([1-9][0-9]*\)|unhealthy|restarting)/ {next}
            (line ~ /syncthing/ && line ~ /(failed|failure|error|timeout|out of sync|folder marker|conflict|connection refused|no such host)/) {next}
            (line ~ /(nvim|marksman|lua_ls|overseer)/ && line ~ /(error|warn|failed|failure|traceback|panic|exception)/) {next}
            (line ~ /(reaper|yabridge|wineasio|wine)/ && line ~ /(failed|failure|error|timeout|crash)/) {next}
            line ~ /(authentication failure|failed password|pam_.*(failure|error)|polkit.*(error|failed|denied)|audit.*(denied|apparmor|selinux|avc)|permission denied)/ {next}
            (line ~ /nvidia-modeset/ && line ~ /warning/) {next}
            (line ~ /(nvrm:|drm|libinput)/ && line ~ /(xid|failed|error)/) {next}
            line ~ /(oom-kill|out of memory|i\/o error|ext4-fs error|bug:|warning: cpu|call trace|machine check)/ {next}
            line ~ /mce:.*(hardware error|error|cpu|bank|status)/ {next}
            (line ~ /btrfs/ && line ~ /(error|corrupt)/) {next}
            (line ~ /amdgpu/ && line ~ /(mode2 reset|gpu reset|timeout|failed|error|ring .* timeout)/) {next}
            (line ~ /thermal/ && line ~ /(critical|thrott)/) {next}
            (line ~ /nvme/ && line ~ /(error|reset|timeout|critical|smart|abort)/) {next}
            (line ~ /ata[0-9]/ && line ~ /(error|failed|timeout|hard resetting)/) {next}
            (line ~ /ext4-fs/ && line ~ /(error|warning)/) {next}
            (line ~ /btrfs/ && line ~ /(warning|corrupt)/) {next}
            (line ~ /xfs/ && line ~ /(error|corrupt)/) {next}
            (line ~ /filesystem/ && line ~ /remount/) {next}
            line ~ /(coredump|systemd-coredump|core-dump|code=dumped|status=[0-9]+\/(segv|abrt|ill|bus|fpe))/ {next}
            line ~ /(borg-backup|borg backup|pkm-export|pkm .* export|promnesia-index|promnesia index|send-ifconfig|compositor|display-health-check)/ {next}
            line ~ /(ufw block|kkeyserver|translation|desktop file.*exec|the directory .* does not exist|flameshot.*(qpainter|qlayout|painter)|xdg-desktop-portal.*icon validation|kded6.*d->name\.isempty|kscreenlocker_greet.*(hunspell|overrides a member)|org_kde_powerdevil.*dw_watch_display_connections)/ {next}
            NF {
                print
            }
        '
}

unclassified_warning_family_lines() {
    unclassified_warning_lines |
        awk '
            {
                original = $0
                line = $0
                sub(/^\[(user|system)\] /, "", line)
                sub(/^[A-Z][a-z][a-z] [ 0-9][0-9] [0-9:]+ [^ ]+ /, "", line)
                family = line
                sub(/\[[0-9]+\]/, "", family)
                gsub(/event[0-9]+/, "eventN", family)
                gsub(/0x[0-9A-Fa-f]+/, "0xHEX", family)
                gsub(/[0-9][0-9][0-9]+/, "N", family)
                gsub(/[[:space:]]+/, " ", family)
                if (length(family) > 140) {
                    family = substr(family, 1, 140)
                }
                count[family]++
                if (!(family in sample)) {
                    sample[family] = original
                }
            }
            END {
                for (family in count) {
                    print count[family] "\t" family "\t" sample[family]
                }
            }
        '
}

unclassified_warning_families() {
    unclassified_warning_family_lines |
        sort -rn |
        head -12
}

unclassified_warning_family_count() {
    unclassified_warning_family_lines | count_lines
}

unclassified_warning_top_family_count() {
    unclassified_warning_families | count_lines
}

group_for_unit() {
    unit=$1
    case "$unit" in
    borg-backup@*) printf 'borg-backup\n' ;;
    PKM-export@*) printf 'pkm-export\n' ;;
    promnesia-index.service) printf 'promnesia-index\n' ;;
    compositor.service) printf 'compositor\n' ;;
    send-ifconfig.service) printf 'send-ifconfig\n' ;;
    display-health-check.service) printf 'display-health-check\n' ;;
    dotfiles-health-user-bus-unavailable.service) printf 'dotfiles-health-user-bus-unavailable\n' ;;
    *) printf '%s\n' "$unit" | sed 's/@.*//; s/\.service$//; s/\.timer$//; s/[^A-Za-z0-9._-]/-/g' ;;
    esac
}

title_for_group() {
    group=$1
    case "$group" in
    borg-backup) printf 'Borg backup failures\n' ;;
    pkm-export) printf 'PKM export failures\n' ;;
    promnesia-index) printf 'Promnesia index failures\n' ;;
    compositor) printf 'Compositor failures\n' ;;
    send-ifconfig) printf 'send-ifconfig failures\n' ;;
    display-health-check) printf 'Display health check failures\n' ;;
    dotfiles-health-user-bus-unavailable) printf 'dotfiles-health cannot read user systemd\n' ;;
    *) printf '%s\n' "$group" ;;
    esac
}

severity_for_group() {
    group=$1
    case "$group" in
    borg-backup | send-ifconfig | promnesia-index | pkm-export) printf 'warning\n' ;;
    compositor | display-health-check) printf 'info\n' ;;
    dotfiles-health-user-bus-unavailable) printf 'critical\n' ;;
    *) printf 'warning\n' ;;
    esac
}

manual_reminders() {
    if [ -f "$main_file" ] && grep -q "$manual_start" "$main_file"; then
        sed -n "/$manual_start/,/$manual_end/p" "$main_file"
        return
    fi

    cat <<EOF
$manual_start

## Review Reminders

- [ ] **Open System Health and review today's hidden errors**
  @id todo-check-hidden-errors-today

  Open [[system-health]], review \`Active Issues\`, and inspect each linked page with active signals: \`sources/\` for system domains and \`units/\` for user services.

  \`\`\`remind
  @run dotfiles-health update
  REM AT 20:30
  \`\`\`

- [ ] **Open the System Health digest and review weekly patterns**

  Open [[$(year_month)]], compare the week's repeated failures, and decide whether they should become fixes, ignored noise, or runbooks.

  \`\`\`remind
  @run dotfiles-health update
  REM Mon AT 09:30
  \`\`\`

- [ ] **Review System Health rules and adjust ignored noise**

  Open [[rules]] and promote any noise that now looks like a real symptom; leave ignored only what you understand and accept.

  \`\`\`remind
  REM Lastworkday AT 18:00
  \`\`\`

$manual_end
EOF
}

write_rules() {
    [ -f "$rules_file" ] && return

    cat >"$rules_file" <<'EOF'
# System Health Rules

@tags #system-health #archlinux #ops

This file documents how `dotfiles-health` classifies recurring workstation
signals. It is human-facing policy; the script keeps only a small built-in
classifier so the report remains dependency-free.

## Critical

These should interrupt normal maintenance when they appear.

- Core input services failing repeatedly.
- Backup units failing while the expected backup target is mounted.
- Persistent display recovery failures.
- Repeated application coredumps in the same day.
- Kernel OOM, I/O, filesystem, GPU reset, or thermal-critical signals.

## Warning

These should be reviewed during the daily or weekly workflow.

- `borg-backup@*.service` failures.
- `send-ifconfig.service` failures.
- `promnesia-index.service` failures.
- `PKM-export@*.service` failures.
- Repeated user unit failures after reboot.
- `pacman` hook, DKMS, or `mkinitcpio` warnings after upgrades.
- Xorg `(EE)` lines and repeated display/input `(WW)` lines.
- PipeWire, WirePlumber, or ALSA `No such device`, `out of buffers`, or
  repeated `resync` bursts.
- NetworkManager, DNS, DHCP, VPN, or Tailscale failures.
- Bluetooth controller, firmware, or HCI failures.
- Storage, NVMe, ATA, or filesystem kernel warnings.
- Docker, containerd, Podman, unhealthy containers, or non-zero container exits.
- Syncthing sync, conflict, folder marker, or connection failures.
- Neovim LSP or Overseer warnings from local state logs.
- REAPER, yabridge, WineASIO, or audio-production session failures.
- Authentication, sshd, auditd, or polkit warnings visible without sudo.
- Unclassified journal warning families that repeat or correlate with symptoms.

## Informational

These are useful context but not always actionable.

- `compositor.service` failing because another compositor is already active.
- Toolkit warnings from KDE, Qt, Flameshot, PipeWire, or D-Bus.

## Ignored Noise Candidates

Do not delete these from the report blindly. Promote one to warning when it
correlates with a user-visible problem.

- Repeated `[UFW BLOCK]` multicast lines.
- Promnesia debug Markdown-indexing lines that only mention REAPER or Wine in a note path.
- Missing translation warnings from GUI tools.
- Single-shot `KKeyServer::xcbKeyPressEventToQt failed` bursts.
- Missing Xorg font directories.
- VPN/netlink warnings that only appear around suspend or network transitions.

## Coverage Workflow

Review `[[system-health-coverage]]` before assuming the report covers a domain.
When `[[system-health-unclassified]]` shows a repeated or actionable family,
promote it into a focused detector and add the classification here. If it is
accepted noise, document the reason in this file instead of silently hiding it.
EOF
}

write_runbook() {
    cat >"$runbook_file" <<'EOF'
# System Health Runbook

@tags #system-health #archlinux #ops

This runbook collects safe, bounded commands for manual follow-up when a
System Health report points to hidden workstation issues.

## Daily

```sh
dotfiles-health update
```

```sh
systemctl --user --failed
```

```sh
systemctl --failed
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl --user -p warning..alert --since today -n 300 --pager-end
```

```sh
coredumpctl list --since today --no-pager | sed -n '1,200p'
```

```sh
rg -n '\(EE\)|\(WW\)' /var/log/Xorg.0.log ~/.local/share/xorg/Xorg.0.log | sed -n '1,300p'
```

```sh
tail -300 /var/log/pacman.log
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl -u NetworkManager.service -u systemd-resolved.service -u tailscaled.service --since today -n 300 --pager-end
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl --user -u pipewire.service -u pipewire-pulse.service -u wireplumber.service --since today -n 300 --pager-end
```

## Weekly

```sh
SYSTEMD_PAGER='less -R +G' journalctl --user -p warning..alert --since '7 days ago' -n 500 --pager-end
```

```sh
systemctl --user list-timers --all
```

```sh
dotfiles-health update
```

Then review `[[system-health-coverage]]` and `[[system-health-unclassified]]`.

## Cleanup After Review

Only reset failures after the cause is understood or deliberately ignored.

```sh
systemctl --user reset-failed
```
EOF
}

write_source_page() {
    name=$1
    title=$2
    count=$3
    command_block=$4
    evidence=$5
    case "$name" in
    system-health-bluetooth | system-health-storage) file="$hardware_sources_dir/$name.md" ;;
    system-health-containers | system-health-sync | system-health-editor | system-health-music) file="$app_sources_dir/$name.md" ;;
    *) file="$sources_dir/$name.md" ;;
    esac

    {
        printf '# %s\n\n' "$title"
        printf '@tags #system-health #archlinux #ops\n\n'
        printf 'This source page summarizes one class of hidden system signals and keeps only short evidence plus bounded commands for deeper inspection.\n\n'
        printf 'Last updated: %s\n\n' "$(now_local)"
        printf '## Current Status\n\n'
        printf '%s\n\n' "- Signals: \`$count\`"
        printf '## Evidence\n\n'
        if [ -n "$evidence" ]; then
            printf '```text\n'
            printf '%s\n' "$evidence" | sed -n '1,20p'
            printf '```\n\n'
        else
            printf '%s\n\n' '- No matching signals in the latest report.'
        fi
        printf '## Quick Commands\n\n'
        printf '%s\n' "$command_block"
    } >"$file"
}

write_system_units_page() {
    units=$(system_failed_units)
    count=$(printf '%s\n' "$units" | count_lines)
    commands=$(
        cat <<'EOF'
```sh
systemctl --failed
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl -p warning..alert --since today -n 300 --pager-end
```
EOF
        if [ -n "$units" ]; then
            printf '\n## Unit Commands\n\n'
            printf '%s\n' "$units" | while IFS= read -r unit; do
                [ -n "$unit" ] || continue
                printf '```sh\nSYSTEMD_PAGER='\''less -R +G'\'' journalctl -u %s --since today -n 120 --pager-end\n```\n\n' "$unit"
            done
        fi
    )

    evidence=$(printf '%s\n' "$units" | sed -n '1,20p')
    write_source_page "system-health-system-units" "System Units" "$count" "$commands" "$evidence"
}

write_crashes_page() {
    summary=$(coredump_summary_since "7 days ago")
    count=$(printf '%s\n' "$summary" | awk -F '\t' '{sum += $1} END {print sum + 0}')
    commands=$(
        cat <<'EOF'
```sh
coredumpctl list --since today --no-pager | sed -n '1,200p'
```

```sh
coredumpctl list --since '7 days ago' --no-pager | sed -n '1,300p'
```
EOF
    )

    write_source_page "system-health-crashes" "Application Crashes" "$count" "$commands" "$summary"
}

write_display_page() {
    signals=$(xorg_signal_lines)
    count=$(printf '%s\n' "$signals" | count_lines)
    commands=$(
        cat <<'EOF'
```sh
rg -n '\(EE\)|\(WW\)' /var/log/Xorg.0.log ~/.local/share/xorg/Xorg.0.log | sed -n '1,300p'
```

```sh
journalctl -k --since today -n 1000 --no-pager | rg -i 'nvrm|amdgpu|drm|xorg|libinput' | sed -n '1,300p'
```
EOF
    )

    write_source_page "system-health-display" "Display And Input Logs" "$count" "$commands" "$signals"
}

write_packages_page() {
    signals=$(pacman_signal_lines)
    count=$(printf '%s\n' "$signals" | count_lines)
    commands=$(
        cat <<'EOF'
```sh
tail -300 /var/log/pacman.log
```

```sh
tail -2000 /var/log/pacman.log | rg -n 'error:|failed|WARNING|Error!|exited [1-9]|aborted|Possibly missing firmware' | sed -n '1,300p'
```
EOF
    )

    write_source_page "system-health-packages" "Package And Hook Logs" "$count" "$commands" "$signals"
}

write_kernel_page() {
    signals=$(kernel_signal_lines)
    count=$(printf '%s\n' "$signals" | count_lines)
    commands=$(
        cat <<'EOF'
```sh
SYSTEMD_PAGER='less -R +G' journalctl -k --since today -n 300 --pager-end
```

```sh
journalctl -k --since '7 days ago' -n 2000 --no-pager | rg -i 'oom|i/o error|ext4|btrfs|nvrm|amdgpu|thermal|mce|bug|call trace' | sed -n '1,300p'
```
EOF
    )

    write_source_page "system-health-kernel" "Kernel Signals" "$count" "$commands" "$signals"
}

write_audio_page() {
    signals=$(audio_signal_lines)
    count=$(printf '%s\n' "$signals" | count_lines)
    evidence=$(printf '%s\n' "$signals" | tail -20)
    commands=$(
        cat <<'EOF'
```sh
SYSTEMD_PAGER='less -R +G' journalctl --user -u pipewire.service -u pipewire-pulse.service -u wireplumber.service --since today -n 300 --pager-end
```

```sh
journalctl --user -u pipewire.service -u pipewire-pulse.service -u wireplumber.service --since today -n 1000 --no-pager | rg -i 'spa\.alsa|spa\.audioconvert|no such device|out of buffers|resync|operation not permitted' | sed -n '1,300p'
```
EOF
    )

    write_source_page "system-health-audio" "Audio Signals" "$count" "$commands" "$evidence"
}

write_network_page() {
    signals=$(network_signal_lines)
    count=$(printf '%s\n' "$signals" | count_lines)
    commands=$(
        cat <<'EOF'
```sh
SYSTEMD_PAGER='less -R +G' journalctl -u NetworkManager.service -u systemd-networkd.service -u systemd-resolved.service -u iwd.service -u wpa_supplicant.service -u tailscaled.service --since today -n 300 --pager-end
```

```sh
journalctl -u NetworkManager.service -u systemd-resolved.service -u tailscaled.service --since today -n 1000 --no-pager | rg -i 'failed|failure|error|timeout|unreachable|deauth|disconnect|dhcp|dns|vpn|wireguard' | sed -n '1,300p'
```
EOF
    )

    write_source_page "system-health-network" "Network And DNS Signals" "$count" "$commands" "$signals"
}

