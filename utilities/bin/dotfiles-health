write_editor_page() {
    signals=$(editor_signal_lines)
    count=$(printf '%s\n' "$signals" | count_lines)
    commands=$(
        cat <<'EOF'
```sh
tail -400 ~/.local/state/nvim/logs/lsp.log ~/.local/state/nvim/log ~/.local/state/nvim/overseer.log 2>/dev/null | rg -i 'error|warn|failed|failure|traceback|panic|exception' | sed -n '1,300p'
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl --user --since today -n 300 --pager-end
```
EOF
    )

    write_source_page "system-health-editor" "Editor And LSP Signals" "$count" "$commands" "$signals"
}

