write_security_page() {
    signals=$(security_signal_lines)
    count=$(printf '%s\n' "$signals" | count_lines)
    commands=$(
        cat <<'EOF'
```sh
SYSTEMD_PAGER='less -R +G' journalctl -u sshd.service -u ssh.service -u auditd.service -u polkit.service --since today -n 300 --pager-end
```

```sh
journalctl -u sshd.service -u ssh.service -u auditd.service -u polkit.service --since today -n 1000 --no-pager | rg -i 'authentication failure|failed password|pam_.*(failure|error)|polkit.*(error|failed|denied)|audit.*(denied|apparmor|selinux|avc)|permission denied' | sed -n '1,300p'
```
EOF
    )

    write_source_page "system-health-security" "Auth And Security Signals" "$count" "$commands" "$signals"
}

write_unclassified_page() {
    signals=$(unclassified_warning_lines)
    families=$(unclassified_warning_families)
    count=$(printf '%s\n' "$signals" | count_lines)
    family_count=$(unclassified_warning_family_count)
    file="$discovery_sources_dir/system-health-unclassified.md"

    {
        printf '# Unclassified Journal Warnings\n\n'
        printf '@tags #system-health #archlinux #ops\n\n'
        printf 'This discovery page catches recent journal warnings that did not match an existing System Health classifier, so new failure families can be promoted into explicit rules.\n\n'
        printf 'Last updated: %s\n\n' "$(now_local)"
        printf '## Current Status\n\n'
        printf '%s\n' "- Signals: \`$count\`"
        printf '%s\n\n' "- Families: \`$family_count\`"
        printf '## Families\n\n'
        if [ -n "$families" ]; then
            printf '%s\n' "$families" | while IFS='	' read -r family_count family sample; do
                [ -n "$family" ] || continue
                printf '%s\n' "- \`$family_count\` $(markdown_text "$family")"
                if [ -n "$sample" ]; then
                    printf '  sample: `%s`\n' "$(markdown_text "$sample")"
                fi
            done
            printf '\n'
        else
            printf '%s\n\n' '- No unclassified warning families in the latest report.'
        fi
        printf '## Quick Commands\n\n'
        cat <<'EOF'
```sh
SYSTEMD_PAGER='less -R +G' journalctl --user -p warning..alert --since today -n 500 --pager-end
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl -p warning..alert --since today -n 500 --pager-end
```
EOF
    } >"$file"
}

write_coverage_page() {
    file="$discovery_sources_dir/system-health-coverage.md"

    {
        printf '# System Health Coverage\n\n'
        printf '@tags #system-health #archlinux #ops\n\n'
        printf 'This page documents what the generated health report currently watches, which domains are only partially covered, and how to promote new warnings into durable checks.\n\n'
        printf 'Last updated: %s\n\n' "$(now_local)"
        printf '## Covered Domains\n\n'
        printf '%s\n' "- [[system-health-system-units]]: systemd system unit failures."
        printf '%s\n' "- [[system-health-crashes]]: recent application coredumps."
        printf '%s\n' "- [[system-health-display]]: Xorg, display, GPU, and input signals."
        printf '%s\n' "- [[system-health-packages]]: pacman, DKMS, mkinitcpio, and package hook signals."
        printf '%s\n' "- [[system-health-kernel]]: kernel OOM, call traces, thermal, MCE, and GPU reset signals."
        printf '%s\n' "- [[system-health-audio]]: PipeWire, WirePlumber, and ALSA signals."
        printf '%s\n' "- [[system-health-network]]: NetworkManager, resolved, iwd, wpa_supplicant, Tailscale, DNS, DHCP, and VPN signals."
        printf '%s\n' "- [[system-health-bluetooth]]: bluetoothd and kernel HCI signals."
        printf '%s\n' "- [[system-health-storage]]: kernel storage and filesystem signals."
        printf '%s\n' "- [[system-health-containers]]: Docker, containerd, Podman, and unhealthy/exited containers visible to the user."
        printf '%s\n' "- [[system-health-sync]]: Syncthing user service signals."
        printf '%s\n' "- [[system-health-editor]]: Neovim LSP and Overseer state logs."
        printf '%s\n' "- [[system-health-music]]: REAPER, yabridge, WineASIO, and related user-session signals."
        printf '%s\n' "- [[system-health-security]]: sshd, auditd, polkit, and authentication warnings visible without sudo."
        printf '%s\n' '- [[system-spikes]]: lightweight CPU spike events and attribution captured by `system-spike-watch`.'
        printf '%s\n\n' "- [[system-health-unclassified]]: recent journal warnings that do not match a known classifier."
        printf '## Partial Coverage\n\n'
        printf '%s\n' '- SMART/NVMe device health is limited to kernel symptoms because direct device health checks may need elevated permissions.'
        printf '%s\n' '- Security coverage is limited to journal-visible warnings; privileged audit details may require sudo.'
        printf '%s\n' "- Journal-backed detectors inspect the latest \`$journal_lines\` service entries and \`$kernel_journal_lines\` kernel entries by default so noisy services or drivers cannot make timer runs crawl all logs."
        printf '%s\n' '- CPU spike attribution is best-effort and uses temporal evidence from `/proc` and systemd cgroups; it should name likely causes, not guarantee causality.'
        printf '%s\n' '- Application logs outside known paths are not crawled globally to avoid slow scans and noisy private data dumps.'
        printf '%s\n\n' '- Unclassified warnings are discovery signals; repeated or actionable families should become explicit rules.'
        printf '## Promotion Workflow\n\n'
        printf '%s\n' '1. Review [[system-health-unclassified]] during the daily or weekly review.'
        printf '%s\n' '2. If a family is actionable, add a focused detector to `dotfiles-health` and document it in [[rules]].'
        printf '%s\n' '3. If a family is accepted noise, document why in [[rules]] under ignored noise candidates.'
        printf '%s\n\n' '4. Keep generated evidence short and prefer executable snippets for deeper inspection.'
        printf '## Quick Commands\n\n'
        cat <<'EOF'
```sh
dotfiles-health update
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl --user -p warning..alert --since today -n 500 --pager-end
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl -p warning..alert --since today -n 500 --pager-end
```
EOF
    } >"$file"
}

write_source_pages() {
    write_system_units_page
    write_crashes_page
    write_display_page
    write_packages_page
    write_kernel_page
    write_audio_page
    write_network_page
    write_bluetooth_page
    write_storage_page
    write_containers_page
    write_sync_page
    write_editor_page
    write_music_page
    write_security_page
    write_unclassified_page
    write_coverage_page
}

write_unit_page() {
    group=$1
    units=$2
    file="$units_dir/$group.md"

    {
        printf '# %s\n\n' "$(title_for_group "$group")"
        printf '@tags #system-health #archlinux #ops\n\n'
        printf 'This unit page groups related failed user services and provides bounded journal commands for each current failure.\n\n'
        printf 'Last updated: %s\n\n' "$(now_local)"
        printf '## Current Classification\n\n'
        printf '%s\n' "- Severity: \`$(severity_for_group "$group")\`"
        printf '%s\n\n' "- Group: \`$group\`"
        printf '## Matching Units\n\n'
        if [ -n "$units" ]; then
            printf '%s\n' "$units" | while IFS= read -r unit; do
                [ -n "$unit" ] || continue
                printf '%s\n' "- \`$unit\`"
            done
        else
            printf '%s\n' '- No failed units in the latest report.'
        fi
        printf '\n## Quick Commands\n\n'
        if [ -n "$units" ]; then
            printf '%s\n' "$units" | while IFS= read -r unit; do
                [ -n "$unit" ] || continue
                printf '```sh\nSYSTEMD_PAGER='\''less -R +G'\'' journalctl --user -u %s --since today -n 120 --pager-end\n```\n\n' "$unit"
            done
        fi
        case "$group" in
        borg-backup)
            cat <<'EOF'
```sh
systemctl --user list-units 'borg-backup@*.service' --all
```

```sh
systemctl --user list-timers '*backup*' --all
```
EOF
            ;;
        esac
    } >"$file"
}

write_unit_pages() {
    tmp_groups=$(mktemp)
    rm -f "$units_dir"/*.md

    failed_units | while IFS= read -r unit; do
        [ -n "$unit" ] || continue
        group=$(group_for_unit "$unit")
        printf '%s\t%s\n' "$group" "$unit"
    done >"$tmp_groups"

    if [ ! -s "$tmp_groups" ]; then
        write_unit_page "no-current-failures" ""
        rm -f "$tmp_groups"
        return
    fi

    cut -f1 "$tmp_groups" | sort -u | while IFS= read -r group; do
        units=$(awk -F '\t' -v group="$group" '$1 == group {print $2}' "$tmp_groups")
        write_unit_page "$group" "$units"
    done

    rm -f "$tmp_groups"
}

write_main() {
    count=$(failed_count)
    system_count=$(system_failed_count)
    crashes_count=$(coredump_count_since "7 days ago")
    display_count=$(xorg_signal_count)
    packages_count=$(pacman_signal_count)
    kernel_count=$(kernel_signal_count)
    audio_count=$(audio_signal_count)
    network_count=$(network_signal_count)
    bluetooth_count=$(bluetooth_signal_count)
    storage_count=$(storage_signal_count)
    containers_count=$(container_signal_count)
    sync_count=$(sync_signal_count)
    editor_count=$(editor_signal_count)
    music_count=$(music_signal_count)
    security_count=$(security_signal_count)
    spike_count=$(spike_event_count_today)
    unclassified_count=$(unclassified_warning_top_family_count)
    manual_block=$(manual_reminders)
    groups=$(failed_units | while IFS= read -r unit; do
        [ -n "$unit" ] || continue
        group_for_unit "$unit"
    done | sort -u)

    {
        printf '# System Health\n\n'
        printf '@tags #system-health #archlinux #ops\n\n'
        printf 'This is the main workstation health report: start here to see active hidden failures, then follow the linked source or unit pages for details.\n\n'
        printf 'Last generated: %s\n\n' "$(now_local)"
        printf '## Current Status\n\n'
        printf '%s\n' "- Failed user units: \`$count\`"
        printf '%s\n' "- Failed system units: \`$system_count\`"
        printf '%s\n' "- Coredumps 7d: \`$crashes_count\`"
        printf '%s\n' "- Display/Xorg signals: \`$display_count\`"
        printf '%s\n' "- Package hook signals: \`$packages_count\`"
        printf '%s\n' "- Kernel signals: \`$kernel_count\`"
        printf '%s\n' "- Audio signals: \`$audio_count\`"
        printf '%s\n' "- Network signals: \`$network_count\`"
        printf '%s\n' "- Bluetooth signals: \`$bluetooth_count\`"
        printf '%s\n' "- Storage signals: \`$storage_count\`"
        printf '%s\n' "- Container signals: \`$containers_count\`"
        printf '%s\n' "- Sync signals: \`$sync_count\`"
        printf '%s\n' "- Editor/LSP signals: \`$editor_count\`"
        printf '%s\n' "- Music production signals: \`$music_count\`"
        printf '%s\n' "- Auth/security signals: \`$security_count\`"
        printf '%s\n' "- CPU spike events today: \`$spike_count\`"
        printf '%s\n' "- Top unclassified warning families: \`$unclassified_count\`"
        printf '%s\n' '- Rules: [[rules]]'
        printf '%s\n' '- Runbook: [[runbook]]'
        printf '%s\n' '- Coverage: [[system-health-coverage]]'
        printf '%s\n\n' "- Monthly digest: [[$(year_month)]]"
        printf '## Signal Sources\n\n'
        printf '%s\n' "- [[system-health-system-units]]: \`$system_count failed units\`"
        printf '%s\n' "- [[system-health-crashes]]: \`$crashes_count coredumps 7d\`"
        printf '%s\n' "- [[system-health-display]]: \`$display_count display/input signals\`"
        printf '%s\n' "- [[system-health-packages]]: \`$packages_count package signals\`"
        printf '%s\n' "- [[system-health-kernel]]: \`$kernel_count kernel signals\`"
        printf '%s\n' "- [[system-health-audio]]: \`$audio_count audio signals\`"
        printf '%s\n' "- [[system-health-network]]: \`$network_count network signals\`"
        printf '%s\n' "- [[system-health-bluetooth]]: \`$bluetooth_count bluetooth signals\`"
        printf '%s\n' "- [[system-health-storage]]: \`$storage_count storage signals\`"
        printf '%s\n' "- [[system-health-containers]]: \`$containers_count container signals\`"
        printf '%s\n' "- [[system-health-sync]]: \`$sync_count sync signals\`"
        printf '%s\n' "- [[system-health-editor]]: \`$editor_count editor signals\`"
        printf '%s\n' "- [[system-health-music]]: \`$music_count music production signals\`"
        printf '%s\n' "- [[system-health-security]]: \`$security_count auth/security signals\`"
        printf '%s\n' "- [[system-spikes]]: \`$spike_count CPU spike events today\`"
        printf '%s\n' "- [[system-health-unclassified]]: \`$unclassified_count unclassified families\`"
        printf '%s\n\n' "- [[system-health-coverage]]: coverage map and promotion workflow"
        printf '## Active Issues\n\n'
        if [ "$system_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-system-units]]: \`$system_count units\`"
        fi
        if [ "$crashes_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-crashes]]: \`$crashes_count coredumps 7d\`"
        fi
        if [ "$display_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-display]]: \`$display_count display/input signals\`"
        fi
        if [ "$packages_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-packages]]: \`$packages_count package signals\`"
        fi
        if [ "$kernel_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-kernel]]: \`$kernel_count kernel signals\`"
        fi
        if [ "$audio_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-audio]]: \`$audio_count audio signals\`"
        fi
        if [ "$network_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-network]]: \`$network_count network signals\`"
        fi
        if [ "$bluetooth_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-bluetooth]]: \`$bluetooth_count bluetooth signals\`"
        fi
        if [ "$storage_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-storage]]: \`$storage_count storage signals\`"
        fi
        if [ "$containers_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-containers]]: \`$containers_count container signals\`"
        fi
        if [ "$sync_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-sync]]: \`$sync_count sync signals\`"
        fi
        if [ "$editor_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-editor]]: \`$editor_count editor/LSP signals\`"
        fi
        if [ "$music_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-music]]: \`$music_count music production signals\`"
        fi
        if [ "$security_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-security]]: \`$security_count auth/security signals\`"
        fi
        if [ "$spike_count" -gt 0 ]; then
            printf '%s\n' "- [[system-spikes]]: \`$spike_count CPU spike events today\`"
        fi
        if [ "$unclassified_count" -gt 0 ]; then
            printf '%s\n' "- [[system-health-unclassified]]: \`$unclassified_count warning families need triage\`"
        fi
        if [ -n "$groups" ]; then
            printf '%s\n' "$groups" | while IFS= read -r group; do
                [ -n "$group" ] || continue
                units=$(failed_units | while IFS= read -r unit; do
                    if [ "$(group_for_unit "$unit")" = "$group" ]; then
                        printf '%s\n' "$unit"
                    fi
                done)
                unit_count=$(printf '%s\n' "$units" | awk 'NF {count++} END {print count + 0}')
                if [ "$unit_count" = "1" ]; then
                    printf '%s\n' "- [[$group]]: \`1 unit\`"
                else
                    printf '%s\n' "- [[$group]]: \`$unit_count units\`"
                fi
            done
        fi
        if [ -z "$groups" ] &&
            [ "$system_count" -eq 0 ] &&
            [ "$crashes_count" -eq 0 ] &&
            [ "$display_count" -eq 0 ] &&
            [ "$packages_count" -eq 0 ] &&
            [ "$kernel_count" -eq 0 ] &&
            [ "$audio_count" -eq 0 ] &&
            [ "$network_count" -eq 0 ] &&
            [ "$bluetooth_count" -eq 0 ] &&
            [ "$storage_count" -eq 0 ] &&
            [ "$containers_count" -eq 0 ] &&
            [ "$sync_count" -eq 0 ] &&
            [ "$editor_count" -eq 0 ] &&
            [ "$music_count" -eq 0 ] &&
            [ "$security_count" -eq 0 ] &&
            [ "$spike_count" -eq 0 ] &&
            [ "$unclassified_count" -eq 0 ]; then
            printf '%s\n' '- No active issues in the latest check.'
        fi
        printf '\n## Quick Commands\n\n'
        cat <<'EOF'
```sh
dotfiles-health update
```

```sh
systemctl --user --failed
```

```sh
systemctl --failed
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl --user -p warning..alert --since today -n 300 --pager-end
```

```sh
SYSTEMD_PAGER='less -R +G' journalctl -p warning..alert --since today -n 300 --pager-end
```

EOF
        printf '%s\n' "$manual_block"
    } >"$main_file"
}

update_monthly_digest() {
    report="$reports_dir/$(year_now)/$(year_month).md"
    day=$(today)
    start="<!-- dotfiles-health:$day:start -->"
    end="<!-- dotfiles-health:$day:end -->"
    tmp=$(mktemp)
    section=$(mktemp)

    [ -f "$report" ] || {
        {
            printf '# System Health %s\n\n' "$(year_month)"
            printf '@tags #system-health #archlinux #ops\n\n'
            printf 'This monthly digest keeps compact daily snapshots from `dotfiles-health` so recurring patterns are visible without storing full logs.\n\n'
            printf 'Each day section is replaced in place when the report is regenerated.\n\n'
        } >"$report"
    }

    {
        printf '%s\n' "$start"
        printf '## %s\n\n' "$day"
        printf '%s\n' "- Last generated: $(now_local)"
        printf '%s\n' "- Failed user units: \`$(failed_count)\`"
        printf '%s\n' "- Failed system units: \`$(system_failed_count)\`"
        printf '%s\n' "- Coredumps 7d: \`$(coredump_count_since "7 days ago")\`"
        printf '%s\n' "- Display/Xorg signals: \`$(xorg_signal_count)\`"
        printf '%s\n' "- Package hook signals: \`$(pacman_signal_count)\`"
        printf '%s\n' "- Kernel signals: \`$(kernel_signal_count)\`"
        printf '%s\n' "- Audio signals: \`$(audio_signal_count)\`"
        printf '%s\n' "- Network signals: \`$(network_signal_count)\`"
        printf '%s\n' "- Bluetooth signals: \`$(bluetooth_signal_count)\`"
        printf '%s\n' "- Storage signals: \`$(storage_signal_count)\`"
        printf '%s\n' "- Container signals: \`$(container_signal_count)\`"
        printf '%s\n' "- Sync signals: \`$(sync_signal_count)\`"
        printf '%s\n' "- Editor/LSP signals: \`$(editor_signal_count)\`"
        printf '%s\n' "- Music production signals: \`$(music_signal_count)\`"
        printf '%s\n' "- Auth/security signals: \`$(security_signal_count)\`"
        printf '%s\n' "- CPU spike events today: \`$(spike_event_count_today)\`"
        printf '%s\n\n' "- Top unclassified warning families: \`$(unclassified_warning_top_family_count)\`"
        printf '### Signal Sources\n\n'
        printf '%s\n' "- [[system-health-crashes]]"
        printf '%s\n' "- [[system-health-display]]"
        printf '%s\n' "- [[system-health-packages]]"
        printf '%s\n' "- [[system-health-kernel]]"
        printf '%s\n' "- [[system-health-audio]]"
        printf '%s\n' "- [[system-health-network]]"
        printf '%s\n' "- [[system-health-bluetooth]]"
        printf '%s\n' "- [[system-health-storage]]"
        printf '%s\n' "- [[system-health-containers]]"
        printf '%s\n' "- [[system-health-sync]]"
        printf '%s\n' "- [[system-health-editor]]"
        printf '%s\n' "- [[system-health-music]]"
        printf '%s\n' "- [[system-health-security]]"
        printf '%s\n' "- [[system-spikes]]"
        printf '%s\n' "- [[system-health-unclassified]]"
        printf '%s\n\n' "- [[system-health-coverage]]"
        printf '### Coredumps 7d\n\n'
        if coredump_summary_since "7 days ago" | grep -q .; then
            coredump_summary_since "7 days ago" | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Display/Xorg Signals\n\n'
        if xorg_signal_lines | grep -q .; then
            xorg_signal_lines | sed -n '1,8p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Package Hook Signals\n\n'
        if pacman_signal_lines | grep -q .; then
            pacman_signal_lines | sed -n '1,8p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Kernel Signals\n\n'
        if kernel_signal_lines | grep -q .; then
            kernel_signal_lines | sed -n '1,8p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Audio Signals\n\n'
        if audio_signal_lines | grep -q .; then
            audio_signal_lines | tail -8 | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Network Signals\n\n'
        if network_signal_lines | grep -q .; then
            network_signal_lines | sed -n '1,5p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Bluetooth Signals\n\n'
        if bluetooth_signal_lines | grep -q .; then
            bluetooth_signal_lines | sed -n '1,5p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Storage Signals\n\n'
        if storage_signal_lines | grep -q .; then
            storage_signal_lines | sed -n '1,5p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Container Signals\n\n'
        if container_signal_lines | grep -q .; then
            container_signal_lines | sed -n '1,5p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Sync Signals\n\n'
        if sync_signal_lines | grep -q .; then
            sync_signal_lines | sed -n '1,5p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Editor And LSP Signals\n\n'
        if editor_signal_lines | grep -q .; then
            editor_signal_lines | sed -n '1,5p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Music Production Signals\n\n'
        if music_signal_lines | grep -q .; then
            music_signal_lines | sed -n '1,5p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Auth And Security Signals\n\n'
        if security_signal_lines | grep -q .; then
            security_signal_lines | sed -n '1,5p' | while IFS= read -r line; do
                [ -n "$line" ] || continue
                printf '%s\n' "- $(markdown_text "$line")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Unclassified Warning Families\n\n'
        if unclassified_warning_families | grep -q .; then
            unclassified_warning_families | sed -n '1,8p' | while IFS='	' read -r family_count family sample; do
                [ -n "$family" ] || continue
                printf '%s\n' "- \`$family_count\` $(markdown_text "$family")"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n'
        printf '### Failed Units\n\n'
        if failed_units | grep -q .; then
            failed_units | while IFS= read -r unit; do
                [ -n "$unit" ] || continue
                printf '%s\n' "- \`$unit\`"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n### Failed System Units\n\n'
        if system_failed_units | grep -q .; then
            system_failed_units | while IFS= read -r unit; do
                [ -n "$unit" ] || continue
                printf '%s\n' "- \`$unit\`"
            done
        else
            printf '%s\n' '- None.'
        fi
        printf '\n%s\n' "$end"
    } >"$section"

    awk -v start="$start" -v end="$end" '
        $0 == start {skip = 1; next}
        $0 == end {skip = 0; next}
        skip != 1 {print}
    ' "$report" >"$tmp"

    {
        cat "$tmp"
        printf '\n'
        cat "$section"
    } | compact_blank_lines >"$report"

    rm -f "$tmp" "$section"
}

update() {
    init_run_cache
    ensure_dirs
    write_rules
    write_runbook
    write_unit_pages
    write_source_pages
    write_main
    update_monthly_digest
    printf '%s\n' "$main_file"
}

command=${1:-}
case "$command" in
update) update ;;
report | open) printf '%s\n' "$main_file" ;;
check) systemctl --user --failed --no-pager ;;
*) usage ;;
esac
