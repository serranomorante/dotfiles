    signals=$(music_signal_lines)
    count=$(printf '%s\n' "$signals" | count_lines)
    commands=$(
        cat <<'EOF'
```sh
SYSTEMD_PAGER='less -R +G' journalctl --user --since today -n 500 --pager-end
```

```sh
tail -400 ~/.local/share/yabridge/*.log ~/.config/yabridge/*.log ~/.config/REAPER/*.log 2>/dev/null | rg -i 'failed|failure|error|timeout|crash|exception|segfault' | sed -n '1,300p'
```
