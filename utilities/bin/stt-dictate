#!/usr/bin/env sh

# Purpose: Toggle local speech-to-text dictation through Whisper or Vosk.
# Notes: The recognized text is always copied to the clipboard before an
# optional paste attempt, so non-text targets still leave the result available.

set -u

usage() {
    cat <<'EOF'
Usage:
  stt-dictate [toggle|begin|end|cancel|status]
  stt-dictate transcribe-file --audio-file <wav> [--output <text-file>]

Environment:
  STT_DICTATE_LANG=auto|es|en
  STT_DICTATE_ES_MODEL_DIR=$XDG_DATA_HOME/vosk/vosk-model-small-es-0.42
  STT_DICTATE_EN_MODEL_DIR=$XDG_DATA_HOME/vosk/vosk-model-small-en-us-0.15
  STT_DICTATE_MODEL_DIR=          # legacy single-language nerd-dictation path
  STT_DICTATE_RUNTIME_DIR=$XDG_RUNTIME_DIR/stt-dictate
  STT_DICTATE_SOURCE=source_filter.rnnoise
  STT_DICTATE_SOURCE_FALLBACK=1
  STT_DICTATE_SAMPLE_RATE=44100
  STT_DICTATE_WHISPER_SAMPLE_RATE=16000
  STT_DICTATE_IDLE_TIME=0.1
  STT_DICTATE_DELAY_EXIT=0.35
  STT_DICTATE_TIMEOUT=0
  STT_DICTATE_FULL_SENTENCE=0
  STT_DICTATE_NUMBERS_AS_DIGITS=0
  STT_DICTATE_BACKEND=auto|whisper.cpp|raw-vosk|nerd-dictation
  STT_DICTATE_AUTO_PASTE=1
  STT_DICTATE_PASTE_KEY=ctrl+shift+v
  STT_DICTATE_PROFILE=fast|balanced|accurate
  STT_DICTATE_WHISPER_BIN=$HOME/data/repos/whisper.cpp/build/bin/whisper-cli
  STT_DICTATE_WHISPER_MODEL_DIR=$HOME/data/apps/dev-tools/ai-tools/whisper.cpp/models
  STT_DICTATE_WHISPER_MODEL=      # optional explicit model override
  STT_DICTATE_WHISPER_PROFILE=$HOME/.config/firejail/fj-whisper-cpp.profile
  STT_DICTATE_WHISPER_SERVER=1
  STT_DICTATE_WHISPER_SERVER_START=1
  STT_DICTATE_WHISPER_SERVER_WAIT=30
  STT_DICTATE_WHISPER_SERVER_URL= # defaults to the selected profile port
  STT_DICTATE_WHISPER_BEAM_SIZE=  # profile default
  STT_DICTATE_WHISPER_BEST_OF=    # profile default
  STT_DICTATE_WHISPER_NO_FALLBACK=# profile default
  STT_DICTATE_WHISPER_THREADS=    # profile default
  STT_DICTATE_TRANSCRIBER=$HOME/bin/stt-vosk-transcribe
  STT_DICTATE_COMMAND=nerd-dictation
  STT_DICTATE_FIREJAIL=1
  STT_DICTATE_FJ_PY=$HOME/bin/fj-py
  STT_DICTATE_PROJECT_DIR=$HOME/data/apps/audio-tools/stt-dictation
EOF
}

die() {
    notify "STT dictation" "$1"
    printf '%s\n' "stt-dictate: $1" >&2
    exit "${2:-1}"
}

notify() {
    command -v notify-send >/dev/null 2>&1 || return 0
    notify-send "$1" "$2" >/dev/null 2>&1 || true
}

runtime_base=${XDG_RUNTIME_DIR:-/tmp}
data_base=${XDG_DATA_HOME:-"$HOME/.local/share"}
runtime_dir=${STT_DICTATE_RUNTIME_DIR:-"$runtime_base/stt-dictate"}
stt_lang=${STT_DICTATE_LANG:-auto}
es_model_dir=${STT_DICTATE_ES_MODEL_DIR:-"$data_base/vosk/vosk-model-small-es-0.42"}
en_model_dir=${STT_DICTATE_EN_MODEL_DIR:-"$data_base/vosk/vosk-model-small-en-us-0.15"}
model_dir=${STT_DICTATE_MODEL_DIR:-"$es_model_dir"}
backend=${STT_DICTATE_BACKEND:-auto}
dictation_cmd=${STT_DICTATE_COMMAND:-nerd-dictation}
transcriber=${STT_DICTATE_TRANSCRIBER:-"$HOME/bin/stt-vosk-transcribe"}
dictation_profile=${STT_DICTATE_PROFILE:-fast}
whisper_bin=${STT_DICTATE_WHISPER_BIN:-"$HOME/data/repos/whisper.cpp/build/bin/whisper-cli"}
whisper_model_dir=${STT_DICTATE_WHISPER_MODEL_DIR:-"$HOME/data/apps/dev-tools/ai-tools/whisper.cpp/models"}
whisper_profile=${STT_DICTATE_WHISPER_PROFILE:-"$HOME/.config/firejail/fj-whisper-cpp.profile"}
whisper_server_enabled=${STT_DICTATE_WHISPER_SERVER:-1}
whisper_server_start=${STT_DICTATE_WHISPER_SERVER_START:-1}
whisper_server_wait=${STT_DICTATE_WHISPER_SERVER_WAIT:-30}
firejail_enabled=${STT_DICTATE_FIREJAIL:-1}
fj_py=${STT_DICTATE_FJ_PY:-"$HOME/bin/fj-py"}
project_dir=${STT_DICTATE_PROJECT_DIR:-"$HOME/data/apps/audio-tools/stt-dictation"}
dictation_source=${STT_DICTATE_SOURCE:-source_filter.rnnoise}
source_fallback=${STT_DICTATE_SOURCE_FALLBACK:-1}
input_method=${STT_DICTATE_INPUT:-PW-CAT}
sample_rate=${STT_DICTATE_SAMPLE_RATE:-44100}
whisper_sample_rate=${STT_DICTATE_WHISPER_SAMPLE_RATE:-16000}
idle_time=${STT_DICTATE_IDLE_TIME:-0.1}
delay_exit=${STT_DICTATE_DELAY_EXIT:-0.35}
timeout=${STT_DICTATE_TIMEOUT:-0}
full_sentence=${STT_DICTATE_FULL_SENTENCE:-0}
numbers_as_digits=${STT_DICTATE_NUMBERS_AS_DIGITS:-0}
auto_paste=${STT_DICTATE_AUTO_PASTE:-1}
paste_key=${STT_DICTATE_PASTE_KEY:-ctrl+shift+v}

case "$dictation_profile" in
fast)
    whisper_default_model=$whisper_model_dir/ggml-base-q5_1.bin
    whisper_default_port=10301
    whisper_default_beam_size=1
    whisper_default_best_of=1
    whisper_default_no_fallback=1
    whisper_default_threads=8
    ;;
balanced)
    whisper_default_model=$whisper_model_dir/ggml-large-v3-turbo-q5_0.bin
    whisper_default_port=10302
    whisper_default_beam_size=2
    whisper_default_best_of=2
    whisper_default_no_fallback=0
    whisper_default_threads=6
    ;;
accurate)
    whisper_default_model=$whisper_model_dir/ggml-medium.bin
    whisper_default_port=10303
    whisper_default_beam_size=5
    whisper_default_best_of=5
    whisper_default_no_fallback=0
    whisper_default_threads=4
    ;;
*)
    die "unsupported STT_DICTATE_PROFILE: $dictation_profile" 2
    ;;
esac

whisper_model=${STT_DICTATE_WHISPER_MODEL:-"$whisper_default_model"}
whisper_server_port=${STT_DICTATE_WHISPER_SERVER_PORT:-"$whisper_default_port"}
whisper_server_url=${STT_DICTATE_WHISPER_SERVER_URL:-"http://127.0.0.1:$whisper_server_port"}
whisper_sandbox=${STT_DICTATE_WHISPER_SANDBOX:-"stt-whisper-$dictation_profile"}
whisper_beam_size=${STT_DICTATE_WHISPER_BEAM_SIZE:-"$whisper_default_beam_size"}
whisper_best_of=${STT_DICTATE_WHISPER_BEST_OF:-"$whisper_default_best_of"}
whisper_no_fallback=${STT_DICTATE_WHISPER_NO_FALLBACK:-"$whisper_default_no_fallback"}
whisper_threads=${STT_DICTATE_WHISPER_THREADS:-"$whisper_default_threads"}

cookie_file=$runtime_dir/nerd-dictation.cookie
pid_file=$runtime_dir/pid
mode_file=$runtime_dir/mode
phase_file=$runtime_dir/phase
audio_file=$runtime_dir/audio.s16le
audio_wav_file=$runtime_dir/audio.wav
whisper_output_prefix=$runtime_dir/whisper
whisper_text_file=$whisper_output_prefix.txt
whisper_stdout_file=$runtime_dir/whisper.stdout
whisper_server_output_file=$runtime_dir/whisper.server.txt
output_file=$runtime_dir/output
error_file=$runtime_dir/error

append_runtime_path() {
    [ -e "$1" ] || return 0
    stt_firejail_rw_paths="${stt_firejail_rw_paths}
$1"
}

run_nerd_dictation() {
    if [ "$firejail_enabled" = 1 ]; then
        [ -x "$fj_py" ] || die "missing Firejail Python wrapper: $fj_py"
        mkdir -p "$project_dir" || die "cannot create STT project directory: $project_dir"

        stt_firejail_rw_paths=$runtime_dir
        append_runtime_path "$runtime_base/pipewire-0"
        append_runtime_path "$runtime_base/pulse/native"

        FJ_PY_EXTRA_PATHS=$model_dir \
            FJ_PY_WRITABLE_PATHS=$stt_firejail_rw_paths \
            FJ_PY_FORWARD_ENV='PIPEWIRE_REMOTE
PULSE_SERVER' \
            "$fj_py" offline "$project_dir" -- "$dictation_cmd" "$@"
        return $?
    fi

    "$dictation_cmd" "$@"
}

run_vosk_transcriber() {
    language=$1
    shift

    if [ "$firejail_enabled" = 1 ]; then
        [ -x "$fj_py" ] || die "missing Firejail Python wrapper: $fj_py"
        mkdir -p "$project_dir" || die "cannot create STT project directory: $project_dir"

        case "$language" in
        auto)
            stt_firejail_extra_paths=$es_model_dir
            [ "$en_model_dir" = "$es_model_dir" ] || stt_firejail_extra_paths="${stt_firejail_extra_paths}
$en_model_dir"
            ;;
        es)
            stt_firejail_extra_paths=$es_model_dir
            ;;
        en)
            stt_firejail_extra_paths=$en_model_dir
            ;;
        *)
            die "unsupported STT_DICTATE_LANG: $language"
            ;;
        esac

        transcriber_real=$(readlink -f "$transcriber" 2>/dev/null || printf '%s\n' "$transcriber")
        stt_firejail_extra_paths="${stt_firejail_extra_paths}
$transcriber_real"

        FJ_PY_EXTRA_PATHS=$stt_firejail_extra_paths \
            FJ_PY_WRITABLE_PATHS=$runtime_dir \
            "$fj_py" offline "$project_dir" -- "$transcriber_real" \
            --audio-file "$audio_file" \
            --sample-rate "$sample_rate" \
            --language "$language" \
            "$@"
        return $?
    fi

    "$transcriber" \
        --audio-file "$audio_file" \
        --sample-rate "$sample_rate" \
        --language "$language" \
        "$@"
}

append_whisper_decode_args() {
    set -- "$@" --threads "$whisper_threads" --beam-size "$whisper_beam_size" --best-of "$whisper_best_of"
    if [ "$whisper_no_fallback" = 1 ]; then
        set -- "$@" --no-fallback
    fi
    printf '%s\n' "$@"
}

whisper_service_name() {
    printf '%s\n' "stt-whisper@$dictation_profile.service"
}

start_whisper_server() {
    [ "$whisper_server_start" = 1 ] || return 1
    command -v systemctl >/dev/null 2>&1 || return 1
    systemctl --user start "$(whisper_service_name)" >/dev/null 2>>"$error_file" || return 1
}

try_whisper_server() {
    [ "$whisper_server_enabled" = 1 ] || return 1
    command -v curl >/dev/null 2>&1 || return 1

    language=$1
    rm -f "$whisper_server_output_file"

    if run_whisper_server_request "$language"; then
        cat "$whisper_server_output_file" >"$output_file"
        return 0
    fi

    start_whisper_server || return 1

    i=0
    while [ "$i" -lt "$whisper_server_wait" ]; do
        sleep 1
        if run_whisper_server_request "$language"; then
            cat "$whisper_server_output_file" >"$output_file"
            return 0
        fi
        i=$((i + 1))
    done

    return 1
}

run_whisper_server_request() {
    language=$1
    if [ "$firejail_enabled" = 1 ]; then
        command -v /usr/bin/firejail >/dev/null 2>&1 || return 1
        /usr/bin/firejail --join="$whisper_sandbox" \
            /usr/bin/env -i PATH=/usr/bin:/bin \
            curl -fsS -X POST \
            --connect-timeout 1 \
            -F "file=@$audio_wav_file" \
            -F "language=$language" \
            -F "response_format=text" \
            -F "temperature=0.0" \
            -F "temperature_inc=0.2" \
            "$whisper_server_url/inference" >"$whisper_server_output_file" 2>>"$error_file"
        return $?
    fi

    curl -fsS -X POST \
        --connect-timeout 1 \
        -F "file=@$audio_wav_file" \
        -F "language=$language" \
        -F "response_format=text" \
        -F "temperature=0.0" \
        -F "temperature_inc=0.2" \
        "$whisper_server_url/inference" >"$whisper_server_output_file" 2>>"$error_file"
}

run_whisper_transcriber() {
    language=$1
    whisper_bin_real=$(readlink -f "$whisper_bin" 2>/dev/null || printf '%s\n' "$whisper_bin")
    whisper_model_real=$(readlink -f "$whisper_model" 2>/dev/null || printf '%s\n' "$whisper_model")
    whisper_bin_dir=$(dirname "$whisper_bin_real")
    whisper_build_dir=$(dirname "$whisper_bin_dir")
    whisper_lib_dir=$whisper_build_dir/src
    whisper_ggml_lib_dir=$whisper_build_dir/ggml/src
    whisper_cuda_lib_dir=$whisper_ggml_lib_dir/ggml-cuda

    if [ "$firejail_enabled" = 1 ]; then
        [ -x /usr/bin/firejail ] || die "firejail is not installed"
        [ -r "$whisper_profile" ] || die "missing Firejail Whisper profile: $whisper_profile"

        /usr/bin/firejail \
            --profile="$whisper_profile" \
            --net=none \
            --whitelist="$project_dir" \
            --whitelist="$runtime_dir" \
            --read-write="$runtime_dir" \
            --whitelist="$whisper_bin_real" \
            --read-only="$whisper_bin_real" \
            --whitelist="$whisper_model_real" \
            --read-only="$whisper_model_real" \
            --whitelist="$whisper_lib_dir" \
            --read-only="$whisper_lib_dir" \
            --whitelist="$whisper_ggml_lib_dir" \
            --read-only="$whisper_ggml_lib_dir" \
            --whitelist="$whisper_cuda_lib_dir" \
            --read-only="$whisper_cuda_lib_dir" \
            /usr/bin/env -i \
            HOME="$HOME" \
            PATH="${PATH:-/usr/local/bin:/usr/bin:/bin}:/opt/cuda/bin" \
            LD_LIBRARY_PATH="$whisper_lib_dir:$whisper_ggml_lib_dir:$whisper_cuda_lib_dir:${LD_LIBRARY_PATH:+$LD_LIBRARY_PATH:}/opt/cuda/lib64" \
            "$whisper_bin_real" \
            --model "$whisper_model_real" \
            --file "$audio_wav_file" \
            --language "$language" \
            --no-timestamps \
            --output-txt \
            --output-file "$whisper_output_prefix" \
            $(append_whisper_decode_args)
        return $?
    fi

    "$whisper_bin" \
        --model "$whisper_model" \
        --file "$audio_wav_file" \
        --language "$language" \
        --no-timestamps \
        --output-txt \
        --output-file "$whisper_output_prefix" \
        $(append_whisper_decode_args)
}

read_pid() {
    [ -r "$pid_file" ] || return 1
    IFS= read -r pid <"$pid_file" || return 1
    [ -n "$pid" ] || return 1
    case "$pid" in
    *[!0-9]*)
        return 1
        ;;
    esac
    printf '%s\n' "$pid"
}

is_running() {
    pid=$(read_pid) || return 1
    kill -0 "$pid" >/dev/null 2>&1
}

read_phase() {
    [ -r "$phase_file" ] || return 1
    IFS= read -r phase <"$phase_file" || return 1
    [ -n "$phase" ] || return 1
    printf '%s\n' "$phase"
}

is_transcribing() {
    [ "$(read_phase 2>/dev/null || true)" = transcribing ]
}

set_clipboard() {
    if command -v wl-copy >/dev/null 2>&1 && [ -n "${WAYLAND_DISPLAY:-}" ]; then
        wl-copy
    elif command -v xclip >/dev/null 2>&1; then
        xclip -selection clipboard
    else
        return 1
    fi
}

paste_clipboard() {
    [ "$auto_paste" = 1 ] || return 0

    if command -v xdotool >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
        xdotool key --clearmodifiers "$paste_key" >/dev/null 2>&1
        return $?
    fi

    if command -v ydotool >/dev/null 2>&1 && [ -n "${YDOTOOL_SOCKET:-}" ]; then
        case "$paste_key" in
        ctrl+shift+v)
            ydotool key 29:1 42:1 47:1 47:0 42:0 29:0 >/dev/null 2>&1
            return $?
            ;;
        esac
    fi

    return 1
}

clean_text() {
    sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//' "$output_file"
}

pipewire_node_exists() {
    command -v pw-cli >/dev/null 2>&1 || return 1
    pw-cli ls Node 2>/dev/null | grep -F "node.name = \"$1\"" >/dev/null 2>&1
}

select_record_source() {
    selected_record_source=
    [ -n "$dictation_source" ] || return 0

    if pipewire_node_exists "$dictation_source"; then
        selected_record_source=$dictation_source
        return 0
    fi

    if [ "$source_fallback" = 1 ]; then
        notify "STT dictation" "Input source unavailable; using default"
        return 0
    fi

    die "missing PipeWire input source: $dictation_source"
}

whisper_ready() {
    [ -x "$whisper_bin" ] || return 1
    [ -r "$whisper_model" ] || return 1
    [ "$firejail_enabled" != 1 ] || [ -r "$whisper_profile" ] || return 1
}

resolve_backend() {
    case "$backend" in
    auto)
        if whisper_ready; then
            resolved_backend=whisper.cpp
        else
            resolved_backend=raw-vosk
        fi
        ;;
    whisper.cpp | raw-vosk | nerd-dictation)
        resolved_backend=$backend
        ;;
    *)
        die "unsupported STT_DICTATE_BACKEND: $backend"
        ;;
    esac
}

language_models_args() {
    case "$stt_lang" in
    auto)
        [ -d "$es_model_dir" ] || die "missing Spanish Vosk model: $es_model_dir"
        [ -d "$en_model_dir" ] || die "missing English Vosk model: $en_model_dir"
        printf '%s\n' --model "es:$es_model_dir" --model "en:$en_model_dir"
        ;;
    es)
        [ -d "$es_model_dir" ] || die "missing Spanish Vosk model: $es_model_dir"
        printf '%s\n' --model "es:$es_model_dir"
        ;;
    en)
        [ -d "$en_model_dir" ] || die "missing English Vosk model: $en_model_dir"
        printf '%s\n' --model "en:$en_model_dir"
        ;;
    *)
        die "unsupported STT_DICTATE_LANG: $stt_lang"
        ;;
    esac
}

begin_raw_vosk_dictation() {
    command -v pw-cat >/dev/null 2>&1 || die "pw-cat is not installed"
    [ -x "$transcriber" ] || die "missing Vosk transcriber: $transcriber"
    language_models_args >/dev/null
    select_record_source

    mkdir -p "$runtime_dir" || die "cannot create runtime directory: $runtime_dir"

    if is_running; then
        notify "STT dictation" "Already recording"
        return 0
    fi

    : >"$output_file"
    : >"$error_file"
    : >"$audio_file"
    printf '%s\n' "raw-vosk" >"$mode_file"
    printf '%s\n' "recording" >"$phase_file"

    if [ -n "$selected_record_source" ]; then
        pw-cat --record --target "$selected_record_source" --format=s16 --rate "$sample_rate" --channels=1 - >"$audio_file" 2>"$error_file" &
    else
        pw-cat --record --format=s16 --rate "$sample_rate" --channels=1 - >"$audio_file" 2>"$error_file" &
    fi
    printf '%s\n' "$!" >"$pid_file"
    notify "STT dictation" "Recording"
}

begin_whisper_dictation() {
    command -v pw-cat >/dev/null 2>&1 || die "pw-cat is not installed"
    [ -x "$whisper_bin" ] || die "missing whisper.cpp binary: $whisper_bin"
    [ -r "$whisper_model" ] || die "missing whisper.cpp model: $whisper_model"
    [ "$firejail_enabled" != 1 ] || [ -r "$whisper_profile" ] || die "missing Firejail Whisper profile: $whisper_profile"
    select_record_source

    mkdir -p "$runtime_dir" "$project_dir" || die "cannot create STT runtime/project directories"

    if is_running; then
        notify "STT dictation" "Already recording"
        return 0
    fi

    : >"$output_file"
    : >"$error_file"
    : >"$audio_wav_file"
    rm -f "$whisper_text_file" "$whisper_stdout_file" "$whisper_server_output_file"
    printf '%s\n' "whisper.cpp" >"$mode_file"
    printf '%s\n' "recording" >"$phase_file"

    [ "$whisper_server_enabled" = 1 ] && start_whisper_server || true

    if [ -n "$selected_record_source" ]; then
        pw-cat --record --target "$selected_record_source" --container=wav --format=s16 --rate "$whisper_sample_rate" --channels=1 "$audio_wav_file" 2>"$error_file" &
    else
        pw-cat --record --container=wav --format=s16 --rate "$whisper_sample_rate" --channels=1 "$audio_wav_file" 2>"$error_file" &
    fi
    printf '%s\n' "$!" >"$pid_file"
    notify "STT dictation" "Recording"
}

begin_dictation() {
    resolve_backend

    if [ "$resolved_backend" = whisper.cpp ]; then
        begin_whisper_dictation
        return $?
    fi

    if [ "$resolved_backend" = raw-vosk ]; then
        begin_raw_vosk_dictation
        return $?
    fi

    command -v "$dictation_cmd" >/dev/null 2>&1 || die "$dictation_cmd is not installed"
    [ -d "$model_dir" ] || die "missing Vosk model: $model_dir"

    mkdir -p "$runtime_dir" || die "cannot create runtime directory: $runtime_dir"

    if is_running; then
        notify "STT dictation" "Already recording"
        return 0
    fi

    : >"$output_file"
    : >"$error_file"
    printf '%s\n' "nerd-dictation" >"$mode_file"

    full_sentence_flag=
    numbers_as_digits_flag=
    [ "$full_sentence" = 1 ] && full_sentence_flag=--full-sentence
    [ "$numbers_as_digits" = 1 ] && numbers_as_digits_flag=--numbers-as-digits

    run_nerd_dictation begin \
        --cookie "$cookie_file" \
        --vosk-model-dir "$model_dir" \
        --input "$input_method" \
        --sample-rate "$sample_rate" \
        --idle-time "$idle_time" \
        --delay-exit "$delay_exit" \
        --timeout "$timeout" \
        --output STDOUT \
        $full_sentence_flag \
        $numbers_as_digits_flag \
        >"$output_file" 2>"$error_file" &

    printf '%s\n' "$!" >"$pid_file"
    notify "STT dictation" "Recording"
}

finish_raw_vosk_dictation() {
    if ! is_running; then
        rm -f "$pid_file"
        notify "STT dictation" "Not recording"
        return 1
    fi

    pid=$(read_pid) || pid=
    [ -n "$pid" ] && kill -INT "$pid" >/dev/null 2>&1 || true
    printf '%s\n' "transcribing" >"$phase_file"
    notify "STT dictation" "Transcribing"

    i=0
    while is_running && [ "$i" -lt 50 ]; do
        sleep 0.1
        i=$((i + 1))
    done
    [ -n "$pid" ] && is_running && kill "$pid" >/dev/null 2>&1 || true

    rm -f "$pid_file"

    set -- $(language_models_args)
    if ! run_vosk_transcriber "$stt_lang" "$@" >"$output_file" 2>>"$error_file"; then
        err=$(sed -n '1,4p' "$error_file")
        [ -n "$err" ] && printf '%s\n' "$err" >&2
        rm -f "$phase_file"
        notify "STT dictation" "No text recognized"
        return 1
    fi

    finish_output_text
    rc=$?
    rm -f "$phase_file"
    return "$rc"
}

finish_whisper_dictation() {
    if ! is_running; then
        rm -f "$pid_file"
        notify "STT dictation" "Not recording"
        return 1
    fi

    pid=$(read_pid) || pid=
    [ -n "$pid" ] && kill -INT "$pid" >/dev/null 2>&1 || true
    printf '%s\n' "transcribing" >"$phase_file"
    notify "STT dictation" "Transcribing"

    i=0
    while is_running && [ "$i" -lt 50 ]; do
        sleep 0.1
        i=$((i + 1))
    done
    [ -n "$pid" ] && is_running && kill "$pid" >/dev/null 2>&1 || true

    rm -f "$pid_file"

    case "$stt_lang" in
    auto | es | en)
        whisper_language=$stt_lang
        ;;
    *)
        die "unsupported STT_DICTATE_LANG: $stt_lang"
        ;;
    esac

    rm -f "$whisper_text_file" "$whisper_stdout_file" "$whisper_server_output_file" "$output_file"
    if ! try_whisper_server "$whisper_language"; then
        if ! run_whisper_transcriber "$whisper_language" >"$whisper_stdout_file" 2>>"$error_file"; then
            err=$(sed -n '1,6p' "$error_file")
            [ -n "$err" ] && printf '%s\n' "$err" >&2
            rm -f "$phase_file"
            notify "STT dictation" "No text recognized"
            return 1
        fi
        if [ -s "$whisper_text_file" ]; then
            cat "$whisper_text_file" >"$output_file"
        else
            cat "$whisper_stdout_file" >"$output_file"
        fi
    fi

    finish_output_text
    rc=$?
    rm -f "$phase_file"
    return "$rc"
}

finish_output_text() {
    text=$(clean_text)

    if [ -z "$text" ]; then
        err=$(sed -n '1,2p' "$error_file")
        [ -n "$err" ] && printf '%s\n' "$err" >&2
        notify "STT dictation" "No text recognized"
        return 1
    fi

    printf '%s' "$text" | set_clipboard || die "could not copy text to clipboard"

    # Give clipboard managers a short moment to observe the new owner.
    sleep 0.05
    paste_clipboard || true
    notify "STT dictation" "Copied to clipboard"
}

finish_dictation() {
    if ! is_running; then
        rm -f "$pid_file"
        notify "STT dictation" "Not recording"
        return 1
    fi

    if [ -r "$mode_file" ]; then
        IFS= read -r mode <"$mode_file" || mode=
        if [ "$mode" = whisper.cpp ]; then
            finish_whisper_dictation
            return $?
        fi
        if [ "$mode" = raw-vosk ]; then
            finish_raw_vosk_dictation
            return $?
        fi
    fi

    run_nerd_dictation end --cookie "$cookie_file" >/dev/null 2>&1 || true

    i=0
    while is_running && [ "$i" -lt 150 ]; do
        sleep 0.1
        i=$((i + 1))
    done

    if is_running; then
        notify "STT dictation" "Still processing"
        return 1
    fi

    rm -f "$pid_file"
    finish_output_text
}

cancel_dictation() {
    if is_running; then
        if [ -r "$mode_file" ]; then
            IFS= read -r mode <"$mode_file" || mode=
        else
            mode=
        fi
        [ "$mode" = raw-vosk ] || run_nerd_dictation cancel --cookie "$cookie_file" >/dev/null 2>&1 || true
        pid=$(read_pid) || pid=
        [ -n "$pid" ] && kill "$pid" >/dev/null 2>&1 || true
    fi

    rm -f "$pid_file" "$mode_file" "$phase_file" "$cookie_file" "$audio_file" "$audio_wav_file" "$whisper_text_file" "$whisper_stdout_file" "$whisper_server_output_file" "$output_file" "$error_file"
    notify "STT dictation" "Canceled"
}

reset_runtime_files() {
    cookie_file=$runtime_dir/nerd-dictation.cookie
    pid_file=$runtime_dir/pid
    mode_file=$runtime_dir/mode
    phase_file=$runtime_dir/phase
    audio_file=$runtime_dir/audio.s16le
    audio_wav_file=$runtime_dir/audio.wav
    whisper_output_prefix=$runtime_dir/whisper
    whisper_text_file=$whisper_output_prefix.txt
    whisper_stdout_file=$runtime_dir/whisper.stdout
    whisper_server_output_file=$runtime_dir/whisper.server.txt
    output_file=$runtime_dir/output
    error_file=$runtime_dir/error
}

transcribe_file_usage() {
    cat <<'EOF'
Usage: stt-dictate transcribe-file --audio-file <wav> [--output <text-file>]
EOF
}

transcribe_file() {
    transcribe_input=
    transcribe_output=

    while [ "$#" -gt 0 ]; do
        case "$1" in
        --audio-file)
            [ "$#" -ge 2 ] || die "--audio-file requires a value" 2
            transcribe_input=$2
            shift 2
            ;;
        --output)
            [ "$#" -ge 2 ] || die "--output requires a value" 2
            transcribe_output=$2
            shift 2
            ;;
        -h | --help | help)
            transcribe_file_usage
            return 0
            ;;
        *)
            die "unknown transcribe-file option: $1" 2
            ;;
        esac
    done

    [ -n "$transcribe_input" ] || die "transcribe-file needs --audio-file" 2
    [ -r "$transcribe_input" ] || die "missing audio file: $transcribe_input" 2

    runtime_dir=$runtime_dir/file-$$
    mkdir -p "$runtime_dir" "$project_dir" || die "cannot create STT file transcription runtime"
    reset_runtime_files
    : >"$output_file"
    : >"$error_file"

    resolve_backend
    case "$resolved_backend" in
    whisper.cpp)
        [ -x "$whisper_bin" ] || die "missing whisper.cpp binary: $whisper_bin"
        [ -r "$whisper_model" ] || die "missing whisper.cpp model: $whisper_model"
        [ "$firejail_enabled" != 1 ] || [ -r "$whisper_profile" ] || die "missing Firejail Whisper profile: $whisper_profile"
        cp "$transcribe_input" "$audio_wav_file" || die "cannot stage audio file for Whisper transcription"
        case "$stt_lang" in
        auto | es | en)
            whisper_language=$stt_lang
            ;;
        *)
            die "unsupported STT_DICTATE_LANG: $stt_lang"
            ;;
        esac
        if ! try_whisper_server "$whisper_language"; then
            if ! run_whisper_transcriber "$whisper_language" >"$whisper_stdout_file" 2>>"$error_file"; then
                err=$(sed -n '1,6p' "$error_file")
                [ -n "$err" ] && printf '%s\n' "$err" >&2
                rm -rf "$runtime_dir"
                notify "STT dictation" "No text recognized"
                return 1
            fi
            if [ -s "$whisper_text_file" ]; then
                cat "$whisper_text_file" >"$output_file"
            else
                cat "$whisper_stdout_file" >"$output_file"
            fi
        fi
        ;;
    raw-vosk)
        command -v ffmpeg >/dev/null 2>&1 || die "ffmpeg is not installed"
        [ -x "$transcriber" ] || die "missing Vosk transcriber: $transcriber"
        set -- $(language_models_args)
        if ! ffmpeg -hide_banner -loglevel error -y -i "$transcribe_input" -ac 1 -ar "$sample_rate" -f s16le "$audio_file" 2>>"$error_file"; then
            err=$(sed -n '1,4p' "$error_file")
            [ -n "$err" ] && printf '%s\n' "$err" >&2
            rm -rf "$runtime_dir"
            return 1
        fi
        if ! run_vosk_transcriber "$stt_lang" "$@" >"$output_file" 2>>"$error_file"; then
            err=$(sed -n '1,4p' "$error_file")
            [ -n "$err" ] && printf '%s\n' "$err" >&2
            rm -rf "$runtime_dir"
            notify "STT dictation" "No text recognized"
            return 1
        fi
        ;;
    *)
        rm -rf "$runtime_dir"
        die "transcribe-file does not support backend: $resolved_backend" 2
        ;;
    esac

    text=$(clean_text)
    if [ -z "$text" ]; then
        err=$(sed -n '1,2p' "$error_file")
        [ -n "$err" ] && printf '%s\n' "$err" >&2
        rm -rf "$runtime_dir"
        notify "STT dictation" "No text recognized"
        return 1
    fi

    if [ -n "$transcribe_output" ]; then
        printf '%s\n' "$text" >"$transcribe_output"
    else
        printf '%s\n' "$text"
    fi

    rm -rf "$runtime_dir"
}

case "${1:-toggle}" in
toggle)
    if is_running; then
        finish_dictation
    elif is_transcribing; then
        notify "STT dictation" "Still transcribing"
    else
        begin_dictation
    fi
    ;;
begin | start)
    begin_dictation
    ;;
end | stop | finish)
    finish_dictation
    ;;
cancel)
    cancel_dictation
    ;;
status)
    if is_running; then
        printf '%s\n' "recording"
    elif is_transcribing; then
        printf '%s\n' "transcribing"
    else
        printf '%s\n' "idle"
    fi
    ;;
transcribe-file)
    shift
    transcribe_file "$@"
    ;;
-h | --help | help)
    usage
    ;;
*)
    usage >&2
    exit 2
    ;;
esac
