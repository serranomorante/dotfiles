#!/bin/sh
# Purpose: Run a small allowlist of commands from Markdown-generated Remind RUNs.
# Usage: remind-run <command> [args...]
# Notes: Remind notes should reference allowlisted argv, never shell syntax.

set -eu

prog=${0##*/}

usage() {
    cat >&2 <<EOF
Usage:
  $prog <command> [args...]
  $prog --list

Allowed commands:
  agent <todo-id>
  dotfiles-health update
EOF
    exit 2
}

[ "$#" -ge 1 ] || usage

run_async() {
    label=$1
    shift
    unit_id=$(printf '%s' "$label" | tr -c 'A-Za-z0-9_.-' '-')
    unit="remind-run-${unit_id}-$(date +%s)"
    if command -v systemd-run >/dev/null 2>&1; then
        systemd-run --user --collect --unit="$unit" "$@" >/dev/null
    else
        "$@" >/dev/null 2>&1 &
    fi
}

case $1 in
--list)
    printf '%s\n' 'agent <todo-id>'
    printf '%s\n' 'dotfiles-health update'
    ;;
agent)
    shift
    [ "$#" -eq 1 ] || usage
    case $1 in
    *[!A-Za-z0-9._:-]* | "")
        logger -t remind-run "rejected agent TODO id: $1" || true
        printf '%s: rejected agent TODO id: %s\n' "$prog" "$1" >&2
        exit 2
        ;;
    esac
    run_async "agent-$1" "$HOME/bin/foam-remind-agent-run" "$1"
    ;;
dotfiles-health)
    shift
    [ "$#" -eq 1 ] || usage
    case $1 in
    update)
        run_async "dotfiles-health-update" "$HOME/bin/dotfiles-health" update
        ;;
    *)
        logger -t remind-run "rejected dotfiles-health subcommand: $1" || true
        printf '%s: rejected dotfiles-health subcommand: %s\n' "$prog" "$1" >&2
        exit 2
        ;;
    esac
    ;;
*)
    logger -t remind-run "rejected command: $1" || true
    printf '%s: rejected command: %s\n' "$prog" "$1" >&2
    exit 2
    ;;
esac
