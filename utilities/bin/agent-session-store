#!/bin/sh
# Purpose: Compile/cache and run the local agent session store.
# Usage: agent-session-store [--compile-cache]|[--provider codex|claude] [--root PATH] refresh|ids|watch-new|wait-new|current-id ...

set -eu

prog=${0##*/}
repo_source_dir="$HOME/dotfiles/utilities/dot-local/share/dotfiles/agent-session-store"
if [ -n "${DOTFILES_AGENT_SESSION_STORE_SOURCE_DIR:-}" ]; then
    source_dir=$DOTFILES_AGENT_SESSION_STORE_SOURCE_DIR
else
    source_dir="$HOME/.local/share/dotfiles/agent-session-store"
    if [ ! -d "$source_dir" ] && [ -d "$repo_source_dir" ]; then
        source_dir=$repo_source_dir
    fi
fi
cache_dir=${XDG_CACHE_HOME:-"$HOME/.cache"}
build_dir="$cache_dir/dotfiles/agent-session-store"
binary="$build_dir/agent-session-store"
hash_file="$build_dir/source.sha256"

source_hash() {
    [ -d "$source_dir" ] || {
        printf '%s: missing Go source dir: %s\n' "$prog" "$source_dir" >&2
        exit 1
    }
    find -L "$source_dir" -type f \( -name '*.go' -o -name 'go.mod' -o -name 'go.sum' \) -print |
        sort |
        xargs sha256sum |
        sha256sum |
        awk '{print $1}'
}

needs_compile() {
    [ -x "$binary" ] || return 0
    current=$(source_hash)
    previous=$(cat "$hash_file" 2>/dev/null || true)
    [ "$current" != "$previous" ]
}

compile_cache() {
    emit_status=$1
    current=$(source_hash)
    mkdir -p "$build_dir"
    tmp="$binary.tmp.$$"
    trap 'rm -f "$tmp"' EXIT HUP INT TERM
    command -v go >/dev/null 2>&1 || {
        printf '%s: go is required to build %s\n' "$prog" "$source_dir" >&2
        exit 1
    }
    (
        cd "$source_dir"
        GOWORK=off go build -buildvcs=false -trimpath -ldflags="-s -w" -o "$tmp" .
    )
    mv "$tmp" "$binary"
    chmod 755 "$binary"
    printf '%s\n' "$current" >"$hash_file"
    trap - EXIT HUP INT TERM
    if [ "$emit_status" -eq 1 ]; then
        printf 'compiled\n'
    fi
}

case "${1:-}" in
--compile-cache)
    needs_compile && compile_cache 1
    exit 0
    ;;
esac

needs_compile && compile_cache 0
exec "$binary" "$@"
