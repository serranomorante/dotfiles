#!/usr/bin/env sh
# Purpose: Run the Vosk transcription implementation inside Firejail.
# Usage: stt-vosk-transcribe --audio-file raw.pcm --sample-rate 44100 --model es:/path/to/model

set -eu

fj_py=${STT_VOSK_TRANSCRIBE_FJ_PY:-"$HOME/bin/fj-py"}
project_dir=${STT_VOSK_TRANSCRIBE_PROJECT_DIR:-"$HOME/data/apps/audio-tools/stt-dictation"}
impl=${STT_VOSK_TRANSCRIBE_IMPL:-"$HOME/.local/share/dotfiles/stt-vosk-transcribe.py"}

[ -f "$impl" ] || {
    printf '%s\n' "stt-vosk-transcribe: missing implementation: $impl" >&2
    exit 127
}

if [ "${STT_VOSK_TRANSCRIBE_IN_FIREJAIL:-0}" = 1 ]; then
    exec "$impl" "$@"
fi

[ -x "$fj_py" ] || {
    printf '%s\n' "stt-vosk-transcribe: missing Firejail Python wrapper: $fj_py" >&2
    exit 127
}
mkdir -p "$project_dir"

exec "$fj_py" offline "$project_dir" -- "$impl" "$@"
