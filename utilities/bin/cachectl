#!/bin/sh
# Purpose: Read and write small dotfiles cache values through Valkey.
# Usage: cachectl get|set|del|ttl <namespace> <key> [ttl-seconds]
# Notes: Values are read from stdin by `set` and written to stdout by `get`.

set -eu

prog=${0##*/}
prefix=${CACHECTL_PREFIX:-dotfiles:cache:v1}
cli=${CACHECTL_VALKEY_CLI:-valkey-cli}
timeout=${CACHECTL_VALKEY_TIMEOUT:-0.15}
uri=${CACHECTL_VALKEY_URI:-}

die() {
    printf '%s: %s\n' "$prog" "$*" >&2
    exit 2
}

usage() {
    cat >&2 <<EOF
Usage:
  $prog get <namespace> <key>
  $prog set <namespace> <key> <ttl-seconds>
  $prog del <namespace> <key>
  $prog ttl <namespace> <key>
  $prog key <namespace> <key>
  $prog ping

Values for "set" are read from stdin. "get" exits 1 when the key is missing.
Namespace and key may contain letters, numbers, dot, underscore, colon, or dash.
EOF
    exit 2
}

safe_part() {
    value=$1
    label=$2

    case $value in
    '' | *[!A-Za-z0-9_.:-]*)
        die "unsafe $label: $value"
        ;;
    esac
}

cache_key() {
    namespace=$1
    key=$2

    safe_part "$namespace" namespace
    safe_part "$key" key
    printf '%s:%s:%s\n' "$prefix" "$namespace" "$key"
}

run_cli() {
    if [ -n "$uri" ]; then
        "$cli" -u "$uri" -t "$timeout" --raw -e "$@"
    else
        "$cli" -t "$timeout" --raw -e "$@"
    fi
}

[ "$#" -ge 1 ] || usage
command=$1
shift

case $command in
get)
    [ "$#" -eq 2 ] || usage
    key=$(cache_key "$1" "$2")
    exists=$(run_cli EXISTS "$key" 2>/dev/null || true)
    [ "$exists" = "1" ] || exit 1
    run_cli GET "$key"
    ;;
set)
    [ "$#" -eq 3 ] || usage
    ttl=$3
    case $ttl in
    '' | *[!0-9]*)
        die "ttl must be a positive integer"
        ;;
    esac
    [ "$ttl" -gt 0 ] || die "ttl must be greater than zero"
    key=$(cache_key "$1" "$2")
    run_cli -x SETEX "$key" "$ttl" >/dev/null
    ;;
del)
    [ "$#" -eq 2 ] || usage
    key=$(cache_key "$1" "$2")
    run_cli DEL "$key" >/dev/null
    ;;
ttl)
    [ "$#" -eq 2 ] || usage
    key=$(cache_key "$1" "$2")
    run_cli TTL "$key"
    ;;
key)
    [ "$#" -eq 2 ] || usage
    cache_key "$1" "$2"
    ;;
ping)
    [ "$#" -eq 0 ] || usage
    run_cli PING
    ;;
*)
    usage
    ;;
esac
