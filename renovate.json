  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "groupName": "npm managed tools",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepNames": ["yarn"],
      "allowedVersions": "/^1\\./",
      "groupName": "npm managed tools"
    },
    {
      "matchDatasources": ["pypi"],
      "groupName": "python packages"
    },
    {
      "matchDepTypes": ["node-system-default"],
      "allowedVersions": "/^22\\./",
      "groupName": "node runtimes"
    },
    {
      "matchDepTypes": ["node-ansible-language-server"],
      "allowedVersions": "/^24\\./",
      "groupName": "node runtimes"
    },
    {
      "matchDepTypes": ["python-ml-runtime"],
      "allowedVersions": "/^3\\.14\\./",
      "groupName": "python runtimes"
    },
    {
      "matchDepTypes": ["github-release-asset"],
      "groupName": "github release assets"
    },
    {
      "matchDepTypes": ["github-tag"],
      "groupName": "github tagged tools"
    },
    {
      "matchPackageNames": ["microsoft/vscode-js-debug"],
      "allowedVersions": "/^1\\./",
      "groupName": "github tagged tools"
    }
  ]
