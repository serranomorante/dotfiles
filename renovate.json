        "/^playbooks\\/roles\\/30-lang-tools\\/defaults\\/main\\.yml$/"
      ],
      "matchStrings": ["(?:^|\\n)\\s*- name: \"?(?<depName>[^\"\\n]+)\"?\\n\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver",
      "depTypeTemplate": "managed-npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^playbooks\\/roles\\/20-dev-tools\\/defaults\\/main\\/main\\.yml$/"],
