#!/usr/bin/env bash
set -euo pipefail

# Purpose: List or open update diffs captured during Ansible-managed package updates.
# Usage: update-diffs [list [--plain|--color|--no-color]|open] [PATH]

prog=${0##*/}
state_dir=${UPDATE_DIFF_CAPTURE_STATE_DIR:-"$HOME/.local/state/dotfiles/update-diffs"}

usage() {
    cat <<EOF
Usage: $prog [list [--plain|--color|--no-color]|open] [PATH]

Actions:
  list              List captured update diff manifests.
  list --plain      List manifests as stable tab-separated plain text.
  list --color      Force colored list output.
  list --no-color   Disable colored list output.
  open PATH         Open a manifest, item directory, run directory, or repo in Neovim Diffview.
  open              Open the latest captured diff.
EOF
}

manifest_value() {
    local manifest=$1
    local key=$2
    python3 - "$manifest" "$key" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as handle:
    data = json.load(handle)
value = data.get(sys.argv[2])
if value is None:
    sys.exit(1)
print(value)
PY
}

resolve_manifest() {
    local target=${1:-"$state_dir/latest"}
    if [ -f "$target" ]; then
        printf '%s\n' "$target"
        return 0
    fi
    if [ -d "$target/repo" ] && [ -f "$target/manifest.json" ]; then
        printf '%s/manifest.json\n' "$target"
        return 0
    fi
    if [ -d "$target/.git" ]; then
        local parent
        parent=$(dirname "$target")
        [ -f "$parent/manifest.json" ] && {
            printf '%s/manifest.json\n' "$parent"
            return 0
        }
    fi
    if [ -d "$target" ]; then
        find "$target" -path '*/manifest.json' -print | sort | tail -n 1
        return 0
    fi
    return 1
}

colors_enabled() {
    local mode=$1
    case $mode in
    always) return 0 ;;
    never) return 1 ;;
    auto)
        [ -t 1 ] || return 1
        [ -z "${NO_COLOR:-}" ] || return 1
        [ "${TERM:-}" != dumb ] || return 1
        return 0
        ;;
    *) return 1 ;;
    esac
}

status_color() {
    case $1 in
    captured) printf '\033[32m' ;;
    unchanged) printf '\033[36m' ;;
    initial-install | initial-checkout) printf '\033[33m' ;;
    metadata-only) printf '\033[35m' ;;
    failed) printf '\033[31m' ;;
    *) printf '\033[37m' ;;
    esac
}

print_manifest_row() {
    local ecosystem=$1
    local name=$2
    local old=$3
    local new=$4
    local status=$5
    local manifest=$6
    local color=$7

    if [ "$color" = true ]; then
        local reset=$'\033[0m'
        local bold=$'\033[1m'
        local ecosystem_color=$'\033[34m'
        local version_color=$'\033[33m'
        local path_color=$'\033[2;37m'
        local status_style
        status_style=$(status_color "$status")
        printf '%s%s%s\t%s%s%s\t%s%s -> %s%s\t%s%s%s\t%s%s%s\n' \
            "$ecosystem_color" "$ecosystem" "$reset" \
            "$bold" "$name" "$reset" \
            "$version_color" "$old" "$new" "$reset" \
            "$status_style" "$status" "$reset" \
            "$path_color" "$manifest" "$reset"
    else
        printf '%s\t%s\t%s -> %s\t%s\t%s\n' "$ecosystem" "$name" "$old" "$new" "$status" "$manifest"
    fi
}

list_manifests() {
    local color_mode=${1:-auto}
    local color=false
    colors_enabled "$color_mode" && color=true

    [ -d "$state_dir/runs" ] || return 0
    find "$state_dir/runs" -path '*/manifest.json' -print | sort | while IFS= read -r manifest; do
        ecosystem=$(manifest_value "$manifest" ecosystem || printf '?')
        name=$(manifest_value "$manifest" name || printf '?')
        old=$(manifest_value "$manifest" from || printf '-')
        new=$(manifest_value "$manifest" to || printf '-')
        status=$(manifest_value "$manifest" status || printf '?')
        print_manifest_row "$ecosystem" "$name" "$old" "$new" "$status" "$manifest" "$color"
    done
}

open_diff() {
    local manifest
    manifest=$(resolve_manifest "${1:-}") || {
        printf '%s: no captured diff found\n' "$prog" >&2
        exit 1
    }
    local repo range
    repo=$(manifest_value "$manifest" repo_path || true)
    range=$(manifest_value "$manifest" diff_range || true)
    [ -n "$repo" ] || {
        printf '%s: capture has no Diffview repo: %s\n' "$prog" "$manifest" >&2
        exit 1
    }
    [ -n "$range" ] || {
        printf '%s: capture has no Diffview range: %s\n' "$prog" "$manifest" >&2
        exit 1
    }
    command -v nvim >/dev/null 2>&1 || {
        printf '%s: nvim is required\n' "$prog" >&2
        exit 1
    }
    cd "$repo"
    exec nvim -c "DiffviewOpen $range" .
}

main() {
    action=${1:-list}
    case $action in
    list)
        shift || true
        color_mode=auto
        while [ "$#" -gt 0 ]; do
            case $1 in
            --plain | --no-color) color_mode=never ;;
            --color) color_mode=always ;;
            -h | --help)
                usage
                return 0
                ;;
            *)
                usage
                exit 2
                ;;
            esac
            shift
        done
        list_manifests "$color_mode"
        ;;
    open) shift; open_diff "${1:-}" ;;
    -h | --help) usage ;;
    *) usage; exit 2 ;;
    esac
}

main "$@"
