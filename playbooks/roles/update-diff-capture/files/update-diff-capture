        --scope) scope=$2; shift 2 ;;
        --venv) venv=$2; shift 2 ;;
        --name) name=$2; shift 2 ;;
        --to) to_version=$2; shift 2 ;;
        --from) from_version=$2; from_version_set=1; shift 2 ;;
        --from-absent) from_version=; from_version_set=1; shift ;;
        --pip-executable) pip_executable=$2; shift 2 ;;
