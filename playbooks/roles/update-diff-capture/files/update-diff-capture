    git -C "$repo" diff --binary HEAD~1..HEAD >"$item_dir/diff.patch"
    write_manifest "$item_dir/manifest.json" uv-tool "$name" "$from_version" "$to_version" captured artifact "$repo" "$item_dir/diff.patch" "pypi:${name}" "HEAD~1..HEAD" "$created"
    write_summary "$item_dir/summary.md" "uv-tool ${name}" "$from_version" "$to_version" captured artifact "$repo" "HEAD~1..HEAD"
    set_latest "$(dirname "$(dirname "$item_dir")")"
    printf 'captured\t%s\t%s -> %s\t%s\n' "$name" "$from_version" "$to_version" "$item_dir"
}

show_uv_tool_version() {
    local tool_dir=
    local name=

    while [ "$#" -gt 0 ]; do
        case $1 in
        --tool-dir) tool_dir=$2; shift 2 ;;
        --name) name=$2; shift 2 ;;
        -h | --help) usage; exit 0 ;;
        *) die "unknown uv-tool-version option: $1" ;;
        esac
    done

    [ -n "$tool_dir" ] || die "uv-tool-version --tool-dir is required"
    [ -n "$name" ] || die "uv-tool-version --name is required"

    uv_tool_installed_version "$tool_dir" "$name" || true
}

luarocks_installed_version() {
    local luarocks_executable=$1
    local name=$2
    "$luarocks_executable" show --mversion "$name" 2>/dev/null || true
}

luarocks_unpack_one() {
    local luarocks_executable=$1
    local name=$2
    local version=$3
    local out_dir=$4
    mkdir -p "$out_dir"
    (cd "$out_dir" && "$luarocks_executable" unpack --force "$name" "$version" >/dev/null)
}

capture_luarocks() {
    local name=
    local to_version=
    local from_version=
    local from_version_set=0
    local luarocks_executable=

    while [ "$#" -gt 0 ]; do
        case $1 in
        --state-dir) state_dir=$2; shift 2 ;;
        --scope) scope=$2; shift 2 ;;
        --name) name=$2; shift 2 ;;
        --to) to_version=$2; shift 2 ;;
        --from) from_version=$2; from_version_set=1; shift 2 ;;
        --from-absent) from_version=; from_version_set=1; shift ;;
        --luarocks-executable) luarocks_executable=$2; shift 2 ;;
        -h | --help) usage; exit 0 ;;
        *) die "unknown luarocks option: $1" ;;
        esac
    done

    [ -n "$name" ] || die "luarocks --name is required"
    [ -n "$to_version" ] || die "luarocks --to is required"
    [ -n "$luarocks_executable" ] || die "luarocks --luarocks-executable is required"
    [ -x "$luarocks_executable" ] || die "luarocks executable is not executable: $luarocks_executable"
    need git
    need python3

    if [ "$from_version_set" -eq 0 ]; then
        from_version=$(luarocks_installed_version "$luarocks_executable" "$name" || true)
    fi
    local created
    created=$(timestamp_utc)
    local item_dir
    item_dir=$(run_root "$created")/luarocks/$(safe_name "$name")

    if [ -z "$from_version" ]; then
        mkdir -p "$item_dir"
        write_manifest "$item_dir/manifest.json" luarocks "$name" "" "$to_version" initial-install metadata-only "" "" "luarocks:${name}" "" "$created"
        write_summary "$item_dir/summary.md" "luarocks ${name}" "" "$to_version" initial-install metadata-only "" ""
        set_latest "$(dirname "$(dirname "$item_dir")")"
        printf 'initial-install\t%s\t%s\n' "$name" "$to_version"
        return 0
    fi

    if [ "$from_version" = "$to_version" ]; then
        printf 'unchanged\t%s\t%s\n' "$name" "$to_version"
        return 0
    fi

    local tmp
    tmp=$(mktemp -d)
    trap "rm -rf -- $(printf '%q' "$tmp")" EXIT
    mkdir -p "$item_dir"
    mkdir -p "$tmp/before" "$tmp/after"
    if ! luarocks_unpack_one "$luarocks_executable" "$name" "$from_version" "$tmp/before" 2>"$tmp/before-unpack.err"; then
        record_capture_failure "$item_dir" luarocks "$name" "$from_version" "$to_version" "luarocks:${name}" "$created" "$(cat "$tmp/before-unpack.err")"
        return 0
    fi
    if ! luarocks_unpack_one "$luarocks_executable" "$name" "$to_version" "$tmp/after" 2>"$tmp/after-unpack.err"; then
        record_capture_failure "$item_dir" luarocks "$name" "$from_version" "$to_version" "luarocks:${name}" "$created" "$(cat "$tmp/after-unpack.err")"
        return 0
    fi

    local repo=$item_dir/repo
    mkdir -p "$repo"
    git -C "$repo" init -q
    copy_snapshot "$tmp/before" "$repo"
    commit_snapshot "$repo" "before ${name}-${from_version}"
    copy_snapshot "$tmp/after" "$repo"
    commit_snapshot "$repo" "after ${name}-${to_version}"
    git -C "$repo" diff --binary HEAD~1..HEAD >"$item_dir/diff.patch"
    write_manifest "$item_dir/manifest.json" luarocks "$name" "$from_version" "$to_version" captured source "$repo" "$item_dir/diff.patch" "luarocks:${name}" "HEAD~1..HEAD" "$created"
    write_summary "$item_dir/summary.md" "luarocks ${name}" "$from_version" "$to_version" captured source "$repo" "HEAD~1..HEAD"
    set_latest "$(dirname "$(dirname "$item_dir")")"
    printf 'captured\t%s\t%s -> %s\t%s\n' "$name" "$from_version" "$to_version" "$item_dir"
}

show_luarocks_version() {
    local name=
    local luarocks_executable=

    while [ "$#" -gt 0 ]; do
        case $1 in
        --name) name=$2; shift 2 ;;
        --luarocks-executable) luarocks_executable=$2; shift 2 ;;
        -h | --help) usage; exit 0 ;;
        *) die "unknown luarocks-version option: $1" ;;
        esac
    done

    [ -n "$name" ] || die "luarocks-version --name is required"
    [ -n "$luarocks_executable" ] || die "luarocks-version --luarocks-executable is required"
    [ -x "$luarocks_executable" ] || die "luarocks executable is not executable: $luarocks_executable"

    luarocks_installed_version "$luarocks_executable" "$name" || true
}

git_cache_dir() {
    local repo=$1
    printf '%s/cache/git/%s.git\n' "$state_dir" "$(safe_name "$repo")"
}

github_git_helper() {
    local script_dir
    script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)
    local candidate
    for candidate in \
        "$script_dir/dotfiles-github-git" \
        "$HOME/bin/dotfiles-github-git" \
        "$HOME/dotfiles/utilities/bin/dotfiles-github-git"; do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    command -v dotfiles-github-git 2>/dev/null || true
}

is_github_url() {
    case $1 in
    https://github.com/* | http://github.com/*)
        return 0
        ;;
    *)
        return 1
        ;;
    esac
}

remote_git() {
    local repo_url=$1
    shift
    if is_github_url "$repo_url"; then
        local helper
        helper=$(github_git_helper)
        if [ -n "$helper" ]; then
            "$helper" "$@"
            return $?
        fi
    fi
    git "$@"
}

capture_git() {
    local repo_url=
    local dest=
    local to_ref=

    while [ "$#" -gt 0 ]; do
        case $1 in
        --state-dir) state_dir=$2; shift 2 ;;
        --scope) scope=$2; shift 2 ;;
        --repo) repo_url=$2; shift 2 ;;
        --dest) dest=$2; shift 2 ;;
        --to) to_ref=$2; shift 2 ;;
        -h | --help) usage; exit 0 ;;
        *) die "unknown git option: $1" ;;
        esac
    done

    [ -n "$repo_url" ] || die "git --repo is required"
    [ -n "$dest" ] || die "git --dest is required"
    [ -n "$to_ref" ] || die "git --to is required"
    need git
    need python3

    local created
    created=$(timestamp_utc)
    local name
    name=$(basename "$dest")
    local item_dir
    item_dir=$(run_root "$created")/git/$(safe_name "$name")

    local old_commit=
    if [ -d "$dest/.git" ]; then
        old_commit=$(git -C "$dest" rev-parse --verify HEAD 2>/dev/null || true)
    fi

    local cache
    cache=$(git_cache_dir "$repo_url")
    mkdir -p "$(dirname "$cache")"
    if [ -d "$cache" ]; then
        remote_git "$repo_url" -C "$cache" fetch -q --tags --prune origin '+refs/heads/*:refs/heads/*'
    else
        remote_git "$repo_url" clone -q --mirror "$repo_url" "$cache"
    fi

    local new_commit
    new_commit=$(git -C "$cache" rev-parse --verify "${to_ref}^{commit}") || die "unable to resolve git ref: $to_ref"

    if [ -z "$old_commit" ]; then
        mkdir -p "$item_dir"
        write_manifest "$item_dir/manifest.json" git "$name" "" "$new_commit" initial-checkout metadata-only "" "" "$repo_url" "" "$created"
        write_summary "$item_dir/summary.md" "git ${name}" "" "$new_commit" initial-checkout metadata-only "" ""
        set_latest "$(dirname "$(dirname "$item_dir")")"
        printf 'initial-checkout\t%s\t%s\n' "$name" "$new_commit"
        return 0
    fi

    if [ "$old_commit" = "$new_commit" ]; then
        printf 'unchanged\t%s\t%s\n' "$name" "$new_commit"
        return 0
    fi

    mkdir -p "$item_dir"
    local review_repo=$item_dir/repo
    git clone -q "$cache" "$review_repo"
    git -C "$review_repo" checkout -q "$new_commit"
    git -C "$review_repo" diff --binary "$old_commit..$new_commit" >"$item_dir/diff.patch"
    write_manifest "$item_dir/manifest.json" git "$name" "$old_commit" "$new_commit" captured source "$review_repo" "$item_dir/diff.patch" "$repo_url" "$old_commit..$new_commit" "$created"
    write_summary "$item_dir/summary.md" "git ${name}" "$old_commit" "$new_commit" captured source "$review_repo" "$old_commit..$new_commit"
    set_latest "$(dirname "$(dirname "$item_dir")")"
    printf 'captured\t%s\t%s -> %s\t%s\n' "$name" "$old_commit" "$new_commit" "$item_dir"
}

main() {
    [ "$#" -gt 0 ] || { usage; exit 2; }
    case $1 in
    npm) shift; capture_npm "$@" ;;
    npm-version) shift; show_npm_version "$@" ;;
    pip) shift; capture_pip "$@" ;;
    pip-version) shift; show_pip_version "$@" ;;
    uv-tool) shift; capture_uv_tool "$@" ;;
    uv-tool-version) shift; show_uv_tool_version "$@" ;;
    luarocks) shift; capture_luarocks "$@" ;;
    luarocks-version) shift; show_luarocks_version "$@" ;;
    git) shift; capture_git "$@" ;;
    -h | --help) usage ;;
    *) die "unknown action: $1" ;;
    esac
}

main "$@"
