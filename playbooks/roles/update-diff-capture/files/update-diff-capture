    fi
    local created
    created=$(timestamp_utc)
    local item_dir
    item_dir=$(run_root "$created")/pip/$(safe_name "$name")

    if [ -z "$from_version" ]; then
        mkdir -p "$item_dir"
        write_manifest "$item_dir/manifest.json" pip "$name" "" "$to_version" initial-install metadata-only "" "" "pypi:${name}" "" "$created"
        write_summary "$item_dir/summary.md" "pip ${name}" "" "$to_version" initial-install metadata-only "" ""
        set_latest "$(dirname "$(dirname "$item_dir")")"
        printf 'initial-install\t%s\t%s\n' "$name" "$to_version"
        return 0
    fi

    if [ "$from_version" = "$to_version" ]; then
        printf 'unchanged\t%s\t%s\n' "$name" "$to_version"
        return 0
    fi

    local tmp
    tmp=$(mktemp -d)
    trap "rm -rf -- $(printf '%q' "$tmp")" EXIT
    mkdir -p "$item_dir"
    mkdir -p "$tmp/packs-before" "$tmp/packs-after" "$tmp/before" "$tmp/after"
    local before_archive after_archive
    if ! before_archive=$(pip_download_one "$pip_executable" "$venv" "${name}==${from_version}" "$tmp/packs-before" 2>"$tmp/before-download.err"); then
        record_capture_failure "$item_dir" pip "$name" "$from_version" "$to_version" "pypi:${name}" "$created" "$(cat "$tmp/before-download.err")"
        return 0
    fi
    if ! after_archive=$(pip_download_one "$pip_executable" "$venv" "${name}==${to_version}" "$tmp/packs-after" 2>"$tmp/after-download.err"); then
        record_capture_failure "$item_dir" pip "$name" "$from_version" "$to_version" "pypi:${name}" "$created" "$(cat "$tmp/after-download.err")"
        return 0
    fi
    if ! unpack_python_archive "$before_archive" "$tmp/before" 2>"$tmp/before-unpack.err"; then
        record_capture_failure "$item_dir" pip "$name" "$from_version" "$to_version" "pypi:${name}" "$created" "$(cat "$tmp/before-unpack.err")"
        return 0
    fi
    if ! unpack_python_archive "$after_archive" "$tmp/after" 2>"$tmp/after-unpack.err"; then
        record_capture_failure "$item_dir" pip "$name" "$from_version" "$to_version" "pypi:${name}" "$created" "$(cat "$tmp/after-unpack.err")"
        return 0
    fi

    local repo=$item_dir/repo
    mkdir -p "$repo"
    git -C "$repo" init -q
    copy_snapshot "$tmp/before" "$repo"
    commit_snapshot "$repo" "before ${name}==${from_version}"
    copy_snapshot "$tmp/after" "$repo"
    commit_snapshot "$repo" "after ${name}==${to_version}"
    git -C "$repo" diff --binary HEAD~1..HEAD >"$item_dir/diff.patch"
    write_manifest "$item_dir/manifest.json" pip "$name" "$from_version" "$to_version" captured artifact "$repo" "$item_dir/diff.patch" "pypi:${name}" "HEAD~1..HEAD" "$created"
    write_summary "$item_dir/summary.md" "pip ${name}" "$from_version" "$to_version" captured artifact "$repo" "HEAD~1..HEAD"
    set_latest "$(dirname "$(dirname "$item_dir")")"
    printf 'captured\t%s\t%s -> %s\t%s\n' "$name" "$from_version" "$to_version" "$item_dir"
}

