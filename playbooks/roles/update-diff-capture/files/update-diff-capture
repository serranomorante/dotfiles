uv_tool_installed_version() {
    local tool_dir=$1
    local name=$2
    [ -d "$tool_dir" ] || return 1
    python3 - "$tool_dir" "$name" <<'PY'
import email.parser
import pathlib
import re
import sys

tool_dir = pathlib.Path(sys.argv[1]).expanduser()
wanted = re.sub(r"[-_.]+", "-", sys.argv[2].lower())

metadata_files = sorted(tool_dir.glob("*/lib/python*/site-packages/*.dist-info/METADATA"))
for metadata_path in metadata_files:
    try:
        metadata = email.parser.Parser().parsestr(metadata_path.read_text(encoding="utf-8", errors="replace"))
    except OSError:
        continue
    name = metadata.get("Name", "")
    version = metadata.get("Version", "")
    if re.sub(r"[-_.]+", "-", name.lower()) == wanted and version:
        print(version)
        sys.exit(0)
sys.exit(1)
PY
}

