# {{ ansible_managed }}
[Desktop Entry]
Name=(debug) REAPER
Exec=kitty --hold -o env=LC_ALL=C -o env=WINEPREFIX='{{ arch_reaper_wine_setup.wine_prefix }}' {% for env in wine_env_vars.items() %}-o "env={{ env | join('=') }}" {% endfor %} {% for env in pipewire_latency_vars.items() %}-o "env={{ env | join('=') }}" {% endfor %} --directory "{{ arch_reaper_wine_setup.wine_prefix }}/dosdevices/c:/Program Files/REAPER (x64)" firejail --profile={{ ansible_facts.env.HOME }}/.config/firejail/wine.local wine "C:/Program Files/REAPER (x64)/REAPER.exe"
Type=Application
StartupNotify=true
Icon=3716_reaper.0
StartupWMClass=reaper.exe
