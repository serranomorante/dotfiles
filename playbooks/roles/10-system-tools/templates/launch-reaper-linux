#!/usr/bin/env bash
# {{ ansible_managed }}
# Purpose: Launch native Linux REAPER with the same audio-production environment as the Wine setup.
# Usage: launch-reaper-linux [--firejail|--no-firejail] [-- REAPER_ARGS...]
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: launch-reaper-linux [--firejail|--no-firejail] [-- REAPER_ARGS...]

Launch native Linux REAPER without Firejail by default.

Options:
  --firejail     Run REAPER through the configured Wine Firejail profile.
  --no-firejail  Run REAPER directly. This is the default.
  -h, --help     Show this help.

Environment:
  DOTFILES_REAPER_FIREJAIL_SANDBOX_NAME  Override the Firejail sandbox name.
EOF
}

governor_boost_started=0

governor_boost_start() {
  # Raise the CPU governor to performance for low-latency audio while REAPER
  # runs. Authorized for the 'realtime' group via polkit; non-fatal if it fails
  # so REAPER still launches on systems without the boost unit.
  if systemctl start cpu-governor-boost.service 2>/dev/null; then
    governor_boost_started=1
  fi
}

governor_boost_stop() {
  # Restore the previous (idle) governor once REAPER exits. Registered on EXIT so
  # it also runs when the launcher is interrupted by a signal.
  if [ "$governor_boost_started" -eq 1 ]; then
    systemctl stop cpu-governor-boost.service 2>/dev/null || true
    governor_boost_started=0
  fi
}

use_firejail=0
firejail_sandbox_name="${DOTFILES_REAPER_FIREJAIL_SANDBOX_NAME:-wwine-reaper}"
firejail_profile="{{ ansible_facts.env.HOME }}/.config/firejail/wine-reaper.local"
wwine_prepare_args=(--prefix reaper --no-desktop --use-sandbox)
if [ -n "${DOTFILES_REAPER_FIREJAIL_SANDBOX_NAME:-}" ]; then
  wwine_prepare_args+=(--sandbox-name "$firejail_sandbox_name")
fi

sandbox_is_registered() {
  firejail --list 2>/dev/null | awk -F: -v name="$firejail_sandbox_name" '$3 == name { found = 1 } END { exit found ? 0 : 1 }'
}

exec_named_firejail() {
  local -a firejail_command=("$@")
  local lock_dir="${XDG_RUNTIME_DIR:-/tmp}/wwine"
  local lock_key="${firejail_sandbox_name//[^A-Za-z0-9_.-]/_}"
  local sandbox_lock_fd
  local firejail_pid
  local status

  command -v flock >/dev/null 2>&1 || {
    printf 'launch-reaper-linux: cannot serialize Firejail sandbox startup because flock is missing\n' >&2
    exit 1
  }

  mkdir -p "$lock_dir"
  exec {sandbox_lock_fd}>"$lock_dir/${lock_key}.lock"
  flock "$sandbox_lock_fd"

  "${firejail_command[@]}" &
  firejail_pid=$!

  while kill -0 "$firejail_pid" 2>/dev/null; do
    if sandbox_is_registered; then
      break
    fi
    sleep 0.05
  done

  flock -u "$sandbox_lock_fd" || true
  exec {sandbox_lock_fd}>&-

  set +e
  wait "$firejail_pid"
  status=$?
  set -e
  exit "$status"
}

case "${1:-}" in
  --firejail)
    use_firejail=1
    shift
    ;;
  --no-firejail)
    shift
    ;;
  -h|--help)
    usage
    exit 0
    ;;
esac

if [ "${1:-}" = "--" ]; then
  shift
fi

"{{ ansible_facts.env.HOME }}/.local/bin/connect-reaper-to-music-production" &

eval "$("{{ ansible_facts.env.HOME }}/bin/wwine" "${wwine_prepare_args[@]}" prepare-env)"

export WINEDEBUG=-all,+err
{% for env in pipewire_latency_vars.items() %}
export {{ env | join('=') }}
{% endfor %}
cd "{{ ansible_facts.env.HOME }}/data/audio-pjs"

# Boost the CPU governor for the lifetime of this REAPER session and restore it
# on exit (including signals) via the EXIT trap.
trap governor_boost_stop EXIT
governor_boost_start

reaper_cmd=(/usr/bin/reaper "$@")
if [ "$use_firejail" -eq 1 ]; then
  reaper_cmd=(firejail --profile="$firejail_profile" --join-or-start="$firejail_sandbox_name" "${reaper_cmd[@]}")
  exec_named_firejail "${reaper_cmd[@]}"
fi

# Run (not exec) so the EXIT trap restores the governor after REAPER exits.
set +e
"${reaper_cmd[@]}"
status=$?
set -e
exit "$status"
