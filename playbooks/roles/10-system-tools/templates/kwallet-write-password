#!/usr/bin/env python
# {{ ansible_managed }}

import os
import sys

from gi.repository import Gio, GLib


KWALLET_CANDIDATES = (
    ("org.kde.kwalletd6", "/modules/kwalletd6"),
    ("org.kde.kwalletd5", "/modules/kwalletd5"),
)


def usage() -> int:
    print(
        "Usage: kwallet-write-password WALLET FOLDER ENTRY\n"
        "       kwallet-write-password --check [WALLET]",
        file=sys.stderr,
    )
    return 2


def call(bus, service, path, method, signature=None, values=None):
    parameters = None if signature is None else GLib.Variant(signature, values)
    return bus.call_sync(
        service,
        path,
        "org.kde.KWallet",
        method,
        parameters,
        None,
        Gio.DBusCallFlags.ALLOW_INTERACTIVE_AUTHORIZATION,
        25000,
        None,
    )


def find_kwallet(bus):
    configured = os.environ.get("KWALLET_DBUS_SERVICE")
    if configured:
        candidates = ((configured, os.environ.get("KWALLET_DBUS_PATH", "")),)
    else:
        candidates = KWALLET_CANDIDATES

    for service, path in candidates:
        if not path:
            suffix = service.rsplit("kwalletd", 1)[-1]
            path = f"/modules/kwalletd{suffix}"
        try:
            bus.call_sync(
                service,
                path,
                "org.freedesktop.DBus.Introspectable",
                "Introspect",
                None,
                GLib.VariantType("(s)"),
                Gio.DBusCallFlags.ALLOW_INTERACTIVE_AUTHORIZATION,
                10000,
                None,
            )
        except GLib.Error:
            continue
        return service, path

    raise RuntimeError("KWallet DBus service is not responding")


def main() -> int:
    if len(sys.argv) >= 2 and sys.argv[1] == "--check":
        bus = Gio.bus_get_sync(Gio.BusType.SESSION, None)
        find_kwallet(bus)
        return 0

    if len(sys.argv) != 4:
        return usage()

    wallet, folder, key = sys.argv[1:4]
    password = sys.stdin.read()
    appid = os.environ.get("KWALLET_APPID", "KDE System")

    bus = Gio.bus_get_sync(Gio.BusType.SESSION, None)
    service, path = find_kwallet(bus)

    handle = call(bus, service, path, "open", "(sxs)", (wallet, 0, appid)).unpack()[0]
    if handle < 0:
        raise RuntimeError(f"failed to open wallet {wallet}")

    if not call(
        bus, service, path, "hasFolder", "(iss)", (handle, folder, appid)
    ).unpack()[0]:
        if not call(
            bus, service, path, "createFolder", "(iss)", (handle, folder, appid)
        ).unpack()[0]:
            raise RuntimeError(f"failed to create folder {folder} in wallet {wallet}")

    rc = call(
        bus,
        service,
        path,
        "writePassword",
        "(issss)",
        (handle, folder, key, password, appid),
    ).unpack()[0]
    if rc != 0:
        raise RuntimeError(f"failed to write entry {key} in folder {folder}")

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(f"kwallet-write-password: {exc}", file=sys.stderr)
        raise SystemExit(1)
