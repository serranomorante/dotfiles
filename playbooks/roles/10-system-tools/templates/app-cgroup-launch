#!/bin/sh
# {{ ansible_managed }}
# Purpose: Launch selected desktop applications inside user systemd cgroup scopes.
# Notes: Existing app instances must be closed before a new launch can inherit limits.

set -eu

usage() {
  echo "Usage: app-cgroup-launch <profile> <command> [args...]" >&2
  exit 2
}

[ "$#" -ge 2 ] || usage

profile=$1
shift

case "$profile" in
{% for item in app_cgroup_profiles | dict2items %}
  {{ item.key }})
    unit_prefix={{ item.value.unit_prefix | quote }}
    description={{ item.value.description | quote }}
    cpu_quota={{ item.value.cpu_quota | quote }}
    cpu_weight={{ item.value.cpu_weight | string | quote }}
    io_weight={{ item.value.io_weight | string | quote }}
    nice={{ item.value.nice | string | quote }}
    memory_high={{ item.value.memory_high | quote }}
    memory_max={{ item.value.memory_max | quote }}
    ;;
{% endfor %}
  *)
    usage
    ;;
esac

unit="${unit_prefix}-$(date +%Y%m%d%H%M%S)-$$.scope"

run_scope() {
  exec systemd-run \
    --user \
    --scope \
    --quiet \
    --collect \
    --same-dir \
    --unit="$unit" \
    --description="$description" \
    --nice="$nice" \
    --property="CPUQuota=$cpu_quota" \
    --property="CPUWeight=$cpu_weight" \
    --property="IOWeight=$io_weight" \
    --property="MemoryHigh=$memory_high" \
    --property="MemoryMax=$memory_max" \
    "$@"
}

run_scope_on_host() {
  systemd-run \
    --machine="${target_user}@.host" \
    --user \
    --scope \
    --quiet \
    --collect \
    --same-dir \
    --unit="$unit" \
    --description="$description" \
    --nice="$nice" \
    --property="CPUQuota=$cpu_quota" \
    --property="CPUWeight=$cpu_weight" \
    --property="IOWeight=$io_weight" \
    --property="MemoryHigh=$memory_high" \
    --property="MemoryMax=$memory_max" \
    "$@"
}

if systemctl --user show-environment >/dev/null 2>&1; then
  run_scope "$@"
fi

target_user=${USER:-}
if [ -z "$target_user" ]; then
  target_user=$(id -un)
fi

# Some sandboxed URL handoffs cannot reach the user bus. Prefer the host user
# manager, but fall back to a direct launch so authentication callbacks work.
if run_scope_on_host "$@" 2>/dev/null; then
  exit 0
fi

exec "$@"
