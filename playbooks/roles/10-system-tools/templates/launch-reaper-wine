#!/usr/bin/env bash
# {{ ansible_managed }}
# Purpose: Launch Windows REAPER through wwine without opening a terminal, while capturing launcher logs.
set -euo pipefail

"{{ ansible_facts.env.HOME }}/.local/bin/connect-reaper-to-music-production" &
export LC_ALL=C
{% for name, value in pipewire_latency_vars.items() %}
export {{ name }}={{ value | quote }}
{% endfor %}

cd "{{ arch_reaper_wine_setup.wine_prefix }}/dosdevices/c:/Program Files/REAPER (x64)"
exec "{{ ansible_facts.env.HOME }}/bin/wwine" --prefix reaper --use-sandbox --log-id reaper wine "C:/Program Files/REAPER (x64)/REAPER.exe"
