#!/usr/bin/env bash
# {{ ansible_managed }}
# Purpose: Launch Windows AudioGridderServer through wwine without opening a terminal, while capturing launcher logs.
set -euo pipefail

export LC_ALL=C
{% for name, value in pipewire_latency_vars.items() %}
export {{ name }}={{ value | quote }}
{% endfor %}

cd "{{ arch_reaper_wine_setup.wine_prefix }}/dosdevices/c:/ProgramData/Microsoft/Windows/Start Menu/Programs"
exec "{{ ansible_facts.env.HOME }}/bin/wwine" --prefix reaper --use-sandbox --log-id audiogridder wine "C:/ProgramData/Microsoft/Windows/Start Menu/Programs/AudioGridderServer.lnk"
