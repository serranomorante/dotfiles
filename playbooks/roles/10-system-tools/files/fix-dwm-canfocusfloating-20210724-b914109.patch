 	}
 	if (c) {
@@ -1829,6 +1829,52 @@ togglefloating(const Arg *arg)
 		selmon->sel->sfh = selmon->sel->h;
 		XSetWindowBorder(dpy, selmon->sel->win, scheme[SchemeSel][ColBorder].pixel);
 	}
+	resetcanfocusfloating();
+	arrange(selmon);
+}
+
+void
+resetcanfocusfloating(void)
+{
+	Client *c;
+
+	for (c = selmon->clients; c; c = c->next)
+		if (c->isfloating)
+			c->cantfocus = 0;
+
+	arrange(selmon);
+}
+
+void
+togglecanfocusfloating(const Arg *arg)
+{
+	unsigned int n;
+	Client *c, *cf = NULL;
+
+	(void)arg;
+	if (!selmon->sel)
+		return;
+
+	for (c = selmon->clients; c; c = c->next)
+		if (c->cantfocus)
+			cf = c;
+
+	if (cf) {
+		resetcanfocusfloating();
+		focus(cf);
+	} else {
+		for (n = 0, c = selmon->clients; c; c = c->next)
+			if (c->isfloating)
+				c->cantfocus = !c->cantfocus;
+			else
+				n++;
+
+		if (n && selmon->sel->isfloating) {
+			c = nexttiled(selmon->clients);
+			focus(c);
+		}
+	}
+
 	arrange(selmon);
 }
 
