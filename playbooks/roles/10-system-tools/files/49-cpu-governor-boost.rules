// Allow members of the "realtime" group to start/stop cpu-governor-boost.service
// without authentication, so the REAPER launcher can request the performance
// governor on demand and release it on exit.
polkit.addRule(function (action, subject) {
  if (
    action.id == "org.freedesktop.systemd1.manage-units" &&
    action.lookup("unit") == "cpu-governor-boost.service" &&
    subject.isInGroup("realtime")
  ) {
    return polkit.Result.YES;
  }
});
