{% set figma_api_key = (mcp_server_figma_key.stdout | default('') | trim) if (mcp_server_figma_key.rc | default(1)) == 0 else '' %}
{
  "mcpServers": {
    "reaper": {
      "disabled": true,
      "command": "{{ python_firejail_executable }}",
      "args": [
        "offline",
        "{{ reaper_mcp_server_setup.repo_path }}",
        "--",
        "{{ reaper_mcp_server_setup.repo_path }}/.venv/bin/uv",
        "--directory",
        "{{ reaper_mcp_server_setup.repo_path }}",
        "run",
        "--offline",
        "--no-sync",
        "-m",
        "reaper_mcp_server.server",
        "--reaper-projects-dir",
        "{{ reaper_mcp_server_setup.projects_dir }}"
      ],
      "env": {
        "FJ_PY_PROFILE": "fj-py-mcp-reaper.profile",
        "FJ_PY_EXTRA_PATHS": "{{ reaper_mcp_server_setup.projects_dir }}",
        "FJ_PY_WRITABLE_PATHS": "{{ ansible_facts.env.HOME }}/.cache/uv"
      }
    },
    "Figma": {
      "disabled": true,
      "command": "{{ node_firejail_executable }}",
      "args": [
        "online",
        "{{ node_ai_npm_prefix }}",
        "--",
        "{{ node_system_default_node_path }}",
        "{{ figma_mcp_server_setup.exe_path }}"{% if figma_api_key | length > 0 %},
        "--figma-api-key={{ figma_api_key }}"{% endif %},
        "--skip-image-downloads",
        "--stdio"
      ],
      "env": {
        "FJ_NODE_PROFILE": "fj-node-mcp.profile"
      }
    },
    "figma-comments": {
      "disabled": true,
      "command": "{{ node_firejail_executable }}",
      "args": [
        "online",
        "{{ node_ai_npm_prefix }}",
        "--",
        "/usr/bin/env"{% if figma_api_key | length > 0 %},
        "FIGMA_ACCESS_TOKEN={{ figma_api_key }}"{% endif %},
        "{{ node_system_default_node_path }}",
        "{{ figma_mcp_commentary_server_setup.exe_path }}"
      ],
      "env": {
        "FJ_NODE_PROFILE": "fj-node-mcp.profile"
      }
    },
    "cf-projects": {
      "disabled": true,
      "command": "{{ node_firejail_executable }}",
      "args": [
        "online",
        "{{ node_ai_npm_prefix }}",
        "--",
        "{{ node_system_default_node_path }}",
        "{{ cf_projects_mcp_server_setup.exe_path }}"
      ],
      "env": {
        "FJ_NODE_PROFILE": "fj-node-mcp.profile"
      }
    },
    "chrome-devtools": {
      "disabled": true,
      "command": "{{ node_firejail_executable }}",
      "args": [
        "online",
        "{{ node_ai_npm_prefix }}",
        "--",
        "{{ node_system_default_node_path }}",
        "{{ chrome_devtools_mcp_server_setup.exe_path }}",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics",
        "--no-performance-crux"
      ],
      "env": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1",
        "FJ_NODE_PROFILE": "fj-node-mcp.profile"
      }
    },
    "Context7": {
      "disabled": true,
      "command": "{{ node_firejail_executable }}",
      "args": [
        "online",
        "{{ node_ai_npm_prefix }}",
        "--",
        "{{ node_system_default_node_path }}",
        "{{ context7_mcp_server_setup.exe_path }}"
      ],
      "env": {
        "FJ_NODE_PROFILE": "fj-node-mcp.profile"
      }
    },
    "playwright": {
      "disabled": false,
      "command": "{{ node_firejail_executable }}",
      "args": [
        "online",
        "{{ node_ai_npm_prefix }}",
        "--",
        "{{ node_system_default_node_path }}",
        "{{ playwright_mcp_server_setup.exe_path }}",
        "--cdp-endpoint",
        "http://127.0.0.1:9222",
        "--shared-browser-context"
      ],
      "env": {
        "FJ_NODE_PROFILE": "fj-node-mcp.profile"
      }
    }
  }
}
