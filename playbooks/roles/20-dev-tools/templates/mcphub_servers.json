{% set figma_api_key = (mcp_server_figma_key.stdout | default('') | trim) if (mcp_server_figma_key.rc | default(1)) == 0 else '' %}
{% set postman_api_key = (mcp_server_postman_key.stdout | default('') | trim) if (mcp_server_postman_key.rc | default(1)) == 0 else '' %}
{% set playwright_mcp_browser_key = (var_playwright_mcp_browser_key.stdout | default('') | trim) if (var_playwright_mcp_browser_key.rc | default(1)) == 0 else '' %}
{
  "mcpServers": {
    "figma_http": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "Sentry": {
      "url": "https://mcp.sentry.dev/mcp",
      "type": "http"
    },
    "reaper": {
      "command": "{{ reaper_mcp_server_setup.repo_path }}/.venv/bin/uv",
      "args": [
        "--directory",
        "{{ reaper_mcp_server_setup.repo_path }}",
        "run",
        "-m",
        "reaper_mcp_server.server",
        "--reaper-projects-dir",
        "{{ reaper_mcp_server_setup.projects_dir }}"
      ]
    },
    "Figma": {
      "command": "{{ node_system_default_node_path }}",
      "args": [
        "{{ figma_mcp_server_setup.exe_path }}"{% if figma_api_key | length > 0 %},
        "--figma-api-key={{ figma_api_key }}"{% endif %},
        "--stdio"
      ]
    },
    "figma-comments": {
      "command": "{{ node_system_default_node_path }}",
      "args": [
        "{{ figma_mcp_commentary_server_setup.exe_path }}"
      ]{% if figma_api_key | length > 0 %},
      "env": {
        "FIGMA_ACCESS_TOKEN": "{{ figma_api_key }}"
      }{% endif %}
    },
    "postman-mcp": {
      "command": "{{ node_system_default_node_path }}",
      "args": [
        "{{ postman_mcp_commentary_server_setup.exe_path }}"
      ]{% if postman_api_key | length > 0 %},
      "env": {
        "POSTMAN_API_KEY": "{{ postman_api_key }}"
      }{% endif %}
    },
    "cf-projects": {
      "command": "{{ node_system_default_node_path }}",
      "args": [
        "{{ cf_projects_mcp_server_setup.exe_path }}"
      ]
    },
    "chrome-devtools": {
      "command": "{{ node_system_default_node_path }}",
      "args": [
        "{{ chrome_devtools_mcp_server_setup.exe_path }}",
        "--browser-url=http://127.0.0.1:9222"
      ]
    },
    "Context7": {
      "command": "{{ node_system_default_node_path }}",
      "args": [
        "{{ context7_mcp_server_setup.exe_path }}"
      ]
    },
    "playwright": {
      "command": "{{ node_system_default_node_path }}",
      "args": [
        "{{ playwright_mcp_server_setup.exe_path }}",
        "--extension",
        "--shared-browser-context",
        "--executable-path",
        "/usr/bin/chromium",
        "--browser",
        "chromium"
      ]{% if playwright_mcp_browser_key | length > 0 %},
      "env": {
        "PLAYWRIGHT_MCP_EXTENSION_TOKEN": "{{ playwright_mcp_browser_key }}"
      }{% endif %}
    }
  }
}
