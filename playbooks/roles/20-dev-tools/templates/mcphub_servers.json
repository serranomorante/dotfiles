{
  "mcpServers": {
    "figma_http": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "Sentry": {
      "url": "https://mcp.sentry.dev/mcp",
      "type": "http"
    },
    "reaper": {
      "command": "{{ reaper_mcp_server_setup.repo_path }}/.venv/bin/uv",
      "args": [
        "--directory",
        "{{ reaper_mcp_server_setup.repo_path }}",
        "run",
        "-m",
        "reaper_mcp_server.server",
        "--reaper-projects-dir",
        "{{ reaper_mcp_server_setup.projects_dir }}"
      ]
    },
    "Figma": {
      "command": "{{ figma_mcp_server_setup.exe_path }}",
      "args": [
        "--figma-api-key={{ (mcp_server_figma_key | default({})).stdout | default(None) }}",
        "--stdio"
      ]
    },
    "figma-comments": {
      "command": "{{ figma_mcp_commentary_server_setup.exe_path }}",
      "env": {
        "FIGMA_ACCESS_TOKEN": "{{ (mcp_server_figma_key | default({})).stdout | default(None) }}"
      }
    },
    "postman-mcp": {
      "command": "{{ postman_mcp_commentary_server_setup.exe_path }}",
      "env": {
        "POSTMAN_API_KEY": "{{ (mcp_server_postman_key | default({})).stdout | default(None) }}"
      }
    },
    "cf-projects": {
      "command": "{{ cf_projects_mcp_server_setup.exe_path }}"
    },
    "chrome-devtools": {
      "command": "{{ chrome_devtools_mcp_server_setup.exe_path }}",
      "args": ["--browser-url=http://127.0.0.1:9222"]
    },
    "Context7": {
      "command": "{{ context7_mcp_server_setup.exe_path }}"
    },
    "playwright": {
      "command": "{{ playwright_mcp_server_setup.exe_path }}",
      "args": [
        "--extension",
        "--shared-browser-context",
        "--executable-path",
        "/usr/bin/chromium",
        "--browser",
        "chromium"
      ],
      "env": {
        "PLAYWRIGHT_MCP_EXTENSION_TOKEN": "{{ (var_playwright_mcp_browser_key | default({})).stdout | default(None) }}"
      }
    }
  }
}
