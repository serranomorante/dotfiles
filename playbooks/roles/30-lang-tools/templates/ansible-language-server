#!/usr/bin/env sh
# {{ ansible_managed }}

node_bin="{{ node_volta_home }}/tools/image/node/{{ node_ansible_language_server_version }}/bin/node"
server_bin="{{ node_ansible_language_server_npm_prefix }}/bin/ansible-language-server"
checker_bin="{{ node_user_bin_dir }}/fj-profile-checker"
inherited_profile="${HOME}/.config/firejail/fj-dev-nvim.profile"

is_inside_firejail() {
    [ -d /run/firejail/profile ] && ! ls /run/firejail/profile >/dev/null 2>&1
}

if is_inside_firejail; then
    exec "$checker_bin" "$inherited_profile" -- "$node_bin" "$server_bin" "$@"
fi

project_root=$(pwd -P)
extra_paths="{{ node_ansible_language_server_npm_prefix }}
{{ ansible_facts.env.HOME }}/.config/nvim
{{ ansible_facts.env.HOME }}/dotfiles/nvim/dot-config/nvim
{{ ansible_facts.env.HOME }}/.local/share/uv/tools
{{ ansible_facts.env.HOME }}/.local/share/uv/python"

if [ -n "${FJ_NODE_EXTRA_PATHS:-}" ]; then
    extra_paths="${FJ_NODE_EXTRA_PATHS}
${extra_paths}"
fi

FJ_NODE_EXTRA_PATHS=$extra_paths exec "{{ node_firejail_executable }}" offline "$project_root" -- "$node_bin" "$server_bin" "$@"
